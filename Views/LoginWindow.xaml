<Window x:Class="GoodGovernanceApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:GoodGovernanceApp.Views"
        mc:Ignorable="d"
        Title="Good Governance Management - Login" Height="642" Width="965"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Name="LoginWin">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left panel: logo/branding -->
            <ColumnDefinition Width="*" />
            <!-- Right panel: login card -->
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <!-- ── LEFT PANEL ── -->
        <Border Grid.Column="0"
                Background="{DynamicResource PrimaryHueMidBrush}">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center" Height="358" Width="377">

                <!-- Replace Source with your actual logo path -->

                <Image Width="161" Height="161"
                Stretch="Uniform"
                HorizontalAlignment="Center"
                Margin="0 0 0 24">
                    <Image.Source>
                        <Binding Path="LogoSource">
                        </Binding>
                    </Image.Source>
                </Image>

                <TextBlock Text="{Binding GovernanceName}"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#88000000"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <TextBlock Text="{Binding Address}"
                FontSize="17" FontWeight="Light"
                Foreground="#88000000"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                TextWrapping="Wrap"/>


                <Separator Margin="24 20"
                           Background="Teal"/>

                <TextBlock Text="Transparency · Accountability · Integrity"
                           FontSize="20"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                            Foreground="#88000000"/>
            </StackPanel>
        </Border>

        <!-- ── RIGHT PANEL ── -->
        <Grid Grid.Column="1">
            <materialDesign:Card VerticalAlignment="Center"
                                 Margin="24,0,24,0"
                                 Padding="24" Height="479">
                <StackPanel>

                    <Border CornerRadius="10" Padding="8" MaxHeight="450" Height="138">
                        <Image Source="{Binding SystemPhotoSource}" Stretch="Uniform" />
                    </Border>

                    <TextBlock Text="Welcome Back"
                               FontSize="24" FontWeight="Bold"
                               Margin="0 0 0 8"
                               HorizontalAlignment="Center"
                                Foreground="#88000000"/>
                    <TextBlock Text="Login to your account"
                               FontSize="14" Foreground="Gray"
                               Margin="0 0 0 24"
                               HorizontalAlignment="Center"/>

                    <!-- Username or Email -->
                    <TextBox materialDesign:HintAssist.Hint="Username or Email"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                              Foreground="#88000000"
                             Margin="0 0 0 16"/>

                    <!-- Password -->
                    <PasswordBox materialDesign:HintAssist.Hint="Password"
                                 Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                                 Name="PasswordBoxControl"
                                 Margin="0 0 0 8"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                  Foreground="#88000000"/>

                    <!-- Error / status message -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="Red"
                               Margin="0 0 0 12"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="12"/>

                    <!-- LOGIN button + spinner -->
                    <Grid Margin="0 8 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>


                        <Button Grid.Column="0"
                        Content="Cheat"
                        Command="{Binding CheatCommand}"
                        CommandParameter="{Binding ElementName=LoginWin}"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>

                        <Button Grid.Column="1"
                                Content="LOGIN"
                                Command="{Binding LoginCommand}"
                                CommandParameter="{Binding ElementName=LoginWin}"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>

                        <ProgressBar Grid.Column="2"
                                     Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True"
                                     Width="24" Height="24"
                                     Margin="10 0 0 0"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding IsLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>

                    <Button Content="Database Connection Settings"
                            Command="{Binding OpenDbSettingsCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="0 16 0 0"
                             Foreground="#88000000"/>


                </StackPanel>
            </materialDesign:Card>
        </Grid>

    </Grid>
</Window>
