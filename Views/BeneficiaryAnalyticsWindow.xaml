<Window x:Class="GoodGovernanceApp.Views.BeneficiaryAnalyticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="Beneficiary Analytics" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Row 0: Header -->
            <RowDefinition Height="Auto"/>   <!-- Row 1: CRS Demographic Profile -->
            <RowDefinition Height="Auto"/>   <!-- Row 2: Summary Cards -->
            <RowDefinition Height="*"/>      <!-- Row 3: Charts + DataGrid -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0 0 0 16">
            <TextBlock Text="Beneficiary Analytics" FontSize="28" FontWeight="Light"/>
            <TextBlock Text="{Binding FullName}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0 4 0 0"/>
            <TextBlock Text="{Binding BeneficiaryId, StringFormat='ID: {0}'}" FontSize="14" Foreground="Gray"/>
        </StackPanel>

        <!-- CRS Demographic Profile Card -->
        <materialDesign:Card Grid.Row="1" Margin="0 0 0 16" Padding="16">
            <!-- Single root child for Card: an outer Grid that hosts both states -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- not-found notice -->
                    <RowDefinition Height="Auto"/>  <!-- profile detail -->
                </Grid.RowDefinitions>

                <!-- Not-found notice: shown when no CRS record matches this ID -->
                <StackPanel Grid.Row="0"
                            Visibility="{Binding CrsProfileNotFound, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                Width="18" Height="18"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                Margin="0 0 8 0"/>
                        <TextBlock Text="No CRS record found for this Beneficiary ID."
                                   FontSize="13" FontStyle="Italic"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Profile detail grid: collapsed when CrsProfileNotFound = true -->
                <Grid Grid.Row="1">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CrsProfileNotFound}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="120"/>  <!-- label -->
                    <ColumnDefinition Width="*"/>                    <!-- value -->
                    <ColumnDefinition Width="24"/>                   <!-- gutter -->
                    <ColumnDefinition Width="Auto" MinWidth="120"/>  <!-- label -->
                    <ColumnDefinition Width="*"/>                    <!-- value -->
                    <ColumnDefinition Width="24"/>                   <!-- gutter -->
                    <ColumnDefinition Width="Auto" MinWidth="120"/>  <!-- label -->
                    <ColumnDefinition Width="*"/>                    <!-- value -->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- section title -->
                    <RowDefinition Height="6"/>     <!-- spacer -->
                    <RowDefinition Height="Auto"/>  <!-- row 1 -->
                    <RowDefinition Height="Auto"/>  <!-- row 2 -->
                    <RowDefinition Height="Auto"/>  <!-- row 3 (PWD / Senior) -->
                </Grid.RowDefinitions>

                <!-- Section title -->
                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="8"
                            Orientation="Horizontal" Margin="0 0 0 4">
                    <materialDesign:PackIcon Kind="AccountDetails"
                                            Width="18" Height="18"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            Margin="0 0 8 0"/>
                    <TextBlock Text="CRS Demographic Profile"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="(Civil Registry System — READ ONLY)"
                               FontSize="11" Foreground="Gray"
                               VerticalAlignment="Center" Margin="8 0 0 0"/>
                </StackPanel>

                <!-- Row 2: Sex | Date of Birth | Age -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Sex:"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0 0 8 4"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Sex}"
                           VerticalAlignment="Center" Margin="0 0 0 4"/>

                <TextBlock Grid.Row="2" Grid.Column="3" Text="Date of Birth:"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0 0 8 4"/>
                <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding DisplayDateOfBirth}"
                           VerticalAlignment="Center" Margin="0 0 0 4"/>

                <TextBlock Grid.Row="2" Grid.Column="6" Text="Age:"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0 0 8 4"/>
                <TextBlock Grid.Row="2" Grid.Column="7" Text="{Binding DisplayAge}"
                           VerticalAlignment="Center" Margin="0 0 0 4"/>

                <!-- Row 3: Marital Status | Classifications | Address -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Marital Status:"
                           FontWeight="SemiBold" VerticalAlignment="Top" Margin="0 0 8 4"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MaritalStatus}"
                           VerticalAlignment="Top" Margin="0 0 0 4"/>

                <TextBlock Grid.Row="3" Grid.Column="3" Text="Classifications:"
                           FontWeight="SemiBold" VerticalAlignment="Top" Margin="0 0 8 4"/>
                <TextBlock Grid.Row="3" Grid.Column="4" Text="{Binding Classifications}"
                           VerticalAlignment="Top" Margin="0 0 0 4"/>

                <TextBlock Grid.Row="3" Grid.Column="6" Text="Address:"
                           FontWeight="SemiBold" VerticalAlignment="Top" Margin="0 0 8 4"/>
                <TextBlock Grid.Row="3" Grid.Column="7" Text="{Binding Address}"
                           VerticalAlignment="Top" TextWrapping="Wrap" Margin="0 0 0 4"/>

                <!-- Row 4: PWD details | Senior details -->
                <!-- PWD block -->
                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal" Margin="0 4 0 0">
                    <materialDesign:PackIcon Kind="Wheelchair"
                                            Width="16" Height="16"
                                            VerticalAlignment="Center"
                                            Margin="0 0 6 0">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPwd}" Value="True">
                                        <Setter Property="Foreground" Value="#FF8E24AA"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                    <TextBlock VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="PWD: No"/>
                                <Setter Property="Foreground" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPwd}" Value="True">
                                        <Setter Property="Text" Value="PWD: Yes"/>
                                        <Setter Property="Foreground" Value="#FF8E24AA"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- PWD ID shown only when IsPwd = true -->
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#FF8E24AA" Margin="6 0 0 0"
                               Visibility="{Binding IsPwd, Converter={StaticResource BoolToVis}}">
                        <Run Text="ID:"/>
                        <Run Text="{Binding PwdIdNo}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Senior Citizen block -->
                <StackPanel Grid.Row="4" Grid.Column="3" Grid.ColumnSpan="2"
                            Orientation="Horizontal" Margin="0 4 0 0">
                    <materialDesign:PackIcon Kind="Star"
                                            Width="16" Height="16"
                                            VerticalAlignment="Center"
                                            Margin="0 0 6 0">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSenior}" Value="True">
                                        <Setter Property="Foreground" Value="#FFF57C00"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                    <TextBlock VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Senior Citizen: No"/>
                                <Setter Property="Foreground" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSenior}" Value="True">
                                        <Setter Property="Text" Value="Senior Citizen: Yes"/>
                                        <Setter Property="Foreground" Value="#FFF57C00"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Senior ID shown only when IsSenior = true -->
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#FFF57C00" Margin="6 0 0 0"
                               Visibility="{Binding IsSenior, Converter={StaticResource BoolToVis}}">
                        <Run Text="ID:"/>
                        <Run Text="{Binding SeniorIdNo}"/>
                    </TextBlock>
                </StackPanel>
                </Grid><!-- end inner profile Grid -->
            </Grid><!-- end outer wrapper Grid -->
        </materialDesign:Card>

        <!-- Summary Cards -->
        <Grid Grid.Row="2" Margin="0 0 0 16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Transactions -->
            <materialDesign:Card Grid.Column="0" Margin="4" Padding="16" Background="#FF1E88E5" Foreground="White">
                <StackPanel>
                    <TextBlock Text="Total Transactions" FontSize="14" Opacity="0.8"/>
                    <TextBlock Text="{Binding TotalTransactions}" FontSize="32" FontWeight="Bold" Margin="0 8 0 0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Consolidated Amount -->
            <materialDesign:Card Grid.Column="1" Margin="4" Padding="16" Background="#FF8E24AA" Foreground="White">
                <StackPanel>
                    <TextBlock Text="Consolidated Total" FontSize="14" Opacity="0.8"/>
                    <TextBlock Text="{Binding ConsolidatedAmount, StringFormat='{}{0:C}'}" FontSize="32" FontWeight="Bold" Margin="0 8 0 0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Department Budget Amount -->
            <materialDesign:Card Grid.Column="2" Margin="4" Padding="16" Background="#FFF57C00" Foreground="White">
                <StackPanel>
                    <TextBlock Text="Department Total" FontSize="14" Opacity="0.8"/>
                    <TextBlock Text="{Binding DepartmentBudgetAmount, StringFormat='{}{0:C}'}" FontSize="32" FontWeight="Bold" Margin="0 8 0 0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Total Amount -->
            <materialDesign:Card Grid.Column="3" Margin="4" Padding="16" Background="#FF43A047" Foreground="White">
                <StackPanel>
                    <TextBlock Text="Grand Total" FontSize="14" Opacity="0.8"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:C}'}" FontSize="32" FontWeight="Bold" Margin="0 8 0 0"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Charts & DataGrid -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Transaction Types (Pie Chart) -->
            <materialDesign:Card Grid.Row="0" Grid.Column="0" Margin="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Amount by Transaction Type" FontWeight="SemiBold" Margin="8 8 0 8"/>
                    <lvc:PieChart Grid.Row="1" Series="{Binding TypeBreakdownSeries}" LegendLocation="Bottom" Hoverable="True"/>
                </Grid>
            </materialDesign:Card>

            <!-- Status Breakdown (Pie Chart) -->
            <materialDesign:Card Grid.Row="1" Grid.Column="0" Margin="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Transaction Source Count" FontWeight="SemiBold" Margin="8 8 0 8"/>
                    <lvc:PieChart Grid.Row="1" Series="{Binding StatusBreakdownSeries}" LegendLocation="Bottom" Hoverable="True"/>
                </Grid>
            </materialDesign:Card>

            <!-- Office Breakdown (Pie Chart) -->
            <materialDesign:Card Grid.Row="2" Grid.Column="0" Margin="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Spending by Office Code" FontWeight="SemiBold" Margin="8 8 0 8"/>
                    <lvc:PieChart Grid.Row="1" Series="{Binding OfficeBreakdownSeries}" LegendLocation="Bottom" Hoverable="True"/>
                </Grid>
            </materialDesign:Card>

            <!-- Monthly Trend & Recent Transactions -->
            <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Monthly Trend -->
                <materialDesign:Card Grid.Row="0" Margin="8" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Monthly Trend" FontWeight="SemiBold" Margin="8 8 0 8"/>
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding MonthlyTrendSeries}" Margin="8">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding MonthlyLabels}" />
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis LabelFormatter="{Binding Formatter}" />
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </materialDesign:Card>

                <!-- Recent Transactions DataGrid -->
                <materialDesign:Card Grid.Row="1" Margin="8" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Recent Transactions (Top 10)" FontWeight="SemiBold" Margin="8 8 0 8"/>
                        
                        <DataGrid Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                                  ItemsSource="{Binding RecentTransactions}" Background="Transparent"
                                  HeadersVisibility="Column" GridLinesVisibility="None" RowHeight="35">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="130" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="100"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="150"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='{}{0:C}'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- Loading Indicator -->
        <Border Grid.RowSpan="4" Background="#88000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Width="40" Height="40" Foreground="White"/>
                <TextBlock Text="Generating Analytics..." Foreground="White" FontSize="16" Margin="0 16 0 0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
