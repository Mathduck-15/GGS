<Window x:Class="GoodGovernanceApp.Views.ConsolidatedSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Consolidated Transactions – Search" Height="600" Width="801"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT COLUMN ═══ -->
        <Grid Grid.Column="0" Margin="0 0 20 0">
            <Grid.RowDefinitions>
                <!-- Row 0: Header -->
                <RowDefinition Height="Auto"/>
                <!-- Row 1: Search Mode card (capped so it never eats all space) -->
                <RowDefinition Height="Auto" MaxHeight="290"/>
                <!-- Row 2: Search Input box -->
                <RowDefinition Height="Auto"/>
                <!-- Row 3: Spacer pushes buttons to bottom -->
                <RowDefinition Height="*"/>
                <!-- Row 4: Action buttons always visible at bottom -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0 · Header -->
            <StackPanel Grid.Row="0" Margin="0 0 0 16">
                <TextBlock Text="Search Consolidated Transactions"
                           FontSize="20" FontWeight="Bold" Foreground="#000000"/>
                <TextBlock Text="Choose how you want to view the records."
                           FontSize="13" Foreground="#666666" Margin="0 4 0 0"/>
            </StackPanel>

            <!-- Row 1 · Search Mode Selection (scrollable so it never overflows) -->
            <materialDesign:Card Grid.Row="1" Padding="16" Margin="0 0 0 12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Search Mode" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#000000" Margin="0 0 0 10"/>

                        <RadioButton x:Name="RadioBeneficiaryId"
                                     Content="Search by Beneficiary ID"
                                     GroupName="SearchMode"
                                     FontSize="13" Foreground="#000000"
                                     Margin="0 0 0 6"
                                     Checked="SearchMode_Changed"
                                     Style="{StaticResource MaterialDesignRadioButton}"/>

                        <RadioButton x:Name="RadioFullName"
                                     Content="Search by Full Name"
                                     GroupName="SearchMode"
                                     FontSize="13" Foreground="#000000"
                                     IsChecked="True"
                                     Margin="0 0 0 6"
                                     Checked="SearchMode_Changed"
                                     Style="{StaticResource MaterialDesignRadioButton}"/>



                        <RadioButton x:Name="RadioBarangay"
                                     Content="Search by Barangay"
                                     GroupName="SearchMode"
                                     FontSize="13" Foreground="#000000"
                                     Margin="0 0 0 6"
                                     Checked="SearchMode_Changed"
                                     Style="{StaticResource MaterialDesignRadioButton}"/>

                        <RadioButton x:Name="RadioHouseholdNo"
                                     Content="Search by Household No"
                                     GroupName="SearchMode"
                                     FontSize="13" Foreground="#000000"
                                     Margin="0 0 0 6"
                                     Checked="SearchMode_Changed"
                                     Style="{StaticResource MaterialDesignRadioButton}"/>

                        <RadioButton x:Name="RadioOffice"
                                     Content="Search by Office"
                                     GroupName="SearchMode"
                                     FontSize="13" Foreground="#000000"
                                     Margin="0 0 0 6"
                                     Checked="SearchMode_Changed"
                                     Style="{StaticResource MaterialDesignRadioButton}"/>

                        <RadioButton x:Name="RadioViewAll"
                                     Content="View Entire Table"
                                     GroupName="SearchMode"
                                     FontSize="13" Foreground="#000000"
                                     Margin="0 0 0 0"
                                     Checked="SearchMode_Changed"
                                     Style="{StaticResource MaterialDesignRadioButton}"/>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>

            <!-- Row 2 · Search Input (hidden when View All is selected) -->
            <StackPanel Grid.Row="2" x:Name="SearchInputPanel" Visibility="Visible" Margin="0 0 0 8">
                <TextBlock x:Name="SearchLabel" Text="Enter Full Name:"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#000000" Margin="0 0 0 6"/>
                <Grid>
                    <!-- Plain TextBox — no MaterialDesign style so it always accepts input -->
                    <TextBox x:Name="SearchTextBox"
                             FontSize="14"
                             Foreground="#000000"
                             Background="White"
                             BorderBrush="#AAAAAA"
                             BorderThickness="1"
                             Padding="8 6"
                             CaretBrush="#000000"
                             Height="36"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchTextBox_TextChanged"
                             KeyDown="SearchTextBox_KeyDown"/>

                    <!-- Auto-suggestion Popup -->
                    <Popup x:Name="SuggestionsPopup"
                           PlacementTarget="{Binding ElementName=SearchTextBox}"
                           Placement="Bottom"
                           StaysOpen="False"
                           IsOpen="False"
                           MaxHeight="180">
                        <Border BorderBrush="#AAAAAA" BorderThickness="1" Background="White"
                                Width="{Binding ElementName=SearchTextBox, Path=ActualWidth}">
                            <Grid>
                                <ListBox x:Name="SuggestionsListBox"
                                         SelectionChanged="SuggestionsListBox_SelectionChanged"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         MaxHeight="150"
                                         BorderThickness="0"/>
                                <!-- Shown when nothing matches -->
                                <TextBlock x:Name="NoMatchesText"
                                           Text="No matches found"
                                           Visibility="Collapsed"
                                           FontSize="13"
                                           Foreground="#888888"
                                           FontStyle="Italic"
                                           Padding="10 8"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>

            <!-- Row 3 · Spacer (flexible, pushes buttons to bottom) -->
            <Border Grid.Row="3" Margin="0,45,0,26"/>

            <!-- Row 4 · Action Buttons — always anchored at the bottom -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="CancelButton_Click"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0 0 8 0"/>
                <Button Content="Proceed" Click="ProceedButton_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>

        </Grid>

        <!-- ═══ RIGHT COLUMN · Contextual recent items ═══ -->
        <!-- Visibility is toggled in SearchMode_Changed; Collapsed until a matching mode is active -->
        <materialDesign:Card x:Name="RecentItemsCard"
                             Grid.Column="1" Padding="12"
                             Visibility="Collapsed">
            <StackPanel>
                <!-- Header text is set dynamically in code-behind -->
                <TextBlock x:Name="RecentItemsHeader"
                           Text="Recent Items"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#000000" Margin="0 0 0 8"/>

                <!-- Single reusable list; ItemsSource is swapped per mode -->
                <ListBox x:Name="RecentItemsListBox"
                         SelectionChanged="RecentItemsListBox_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         MaxHeight="480"
                         Style="{StaticResource MaterialDesignListBox}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" Padding="4" Cursor="Hand"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </materialDesign:Card>

    </Grid>
</Window>
