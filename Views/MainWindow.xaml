<Window x:Class="GoodGovernanceApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Good Governance Management System" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Name="MainWin">

    <Grid>
        <materialDesign:DrawerHost x:Name="DrawerHost" IsLeftDrawerOpen="True" OpenMode="Standard">
            <materialDesign:DrawerHost.LeftDrawerContent>
                <Grid Width="250" Background="{DynamicResource MaterialDesignPaper}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="16">
                        <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding OpenAppProfileCommand}" HorizontalAlignment="Left" Width="48" Height="48" Margin="0 0 0 16" Padding="0" ToolTip="Open Application Profile">
                            <materialDesign:PackIcon Kind="BankOutline" Width="48" Height="48" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </Button>
                        <TextBlock Text="{Binding GovernanceName}" 
                        FontSize="20" 
                        FontWeight="Bold"
                        TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Navigation Items -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedNavItem}" Margin="0 11"
                             Style="{StaticResource MaterialDesignNavigationListBox}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8">
                                    <materialDesign:PackIcon Kind="{Binding Icon}" Width="10" Height="10" VerticalAlignment="Center" Margin="0 0 11 0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="10"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Footer / Logout -->
                    <Button Grid.Row="2" Command="{Binding LogoutCommand}" CommandParameter="{Binding ElementName=MainWin}"
                            Style="{StaticResource MaterialDesignFlatButton}" Margin="16" HorizontalAlignment="Left" Foreground="Red">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout" Width="20" Height="20" VerticalAlignment="Center" Margin="0 0 8 0"/>
                            <TextBlock Text="Log Out" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </materialDesign:DrawerHost.LeftDrawerContent>

            <!-- Main Content Area -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top App Bar -->
                <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="16" materialDesign:ElevationAssist.Elevation="Dp4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton Grid.Column="0" Style="{StaticResource MaterialDesignHamburgerToggleButton}" 
                                      IsChecked="{Binding ElementName=DrawerHost, Path=IsLeftDrawerOpen, Mode=TwoWay}" />
                        
                        <TextBlock Grid.Column="1" Text="{Binding SelectedNavItem.Name}" VerticalAlignment="Center" FontSize="20" Margin="16 0 0 0" />
                        
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Image Width="32" Height="32" VerticalAlignment="Center" 
                            Source="{Binding ProfilePhotoSource}" />
                            <StackPanel VerticalAlignment="Center" Margin="8 0 16 0">
                                <TextBlock Text="{Binding CurrentUserName}" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentUserRole}" FontSize="11" Foreground="LightGray"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </materialDesign:ColorZone>

                <!-- Content Area -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="16" />
            </Grid>
        </materialDesign:DrawerHost>
    </Grid>
</Window>
