<Window x:Class="GoodGovernanceApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
        xmlns:converters="clr-namespace:GoodGovernanceApp.Converters"
        Title="Good Governance Management System"
        Height="780" Width="1280"
        MinHeight="640" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F3F5F7"
        FontFamily="Segoe UI"
        Name="MainWin">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/GoodGovernanceApp;component/Views/Styles/MetroTileStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StringToSolidColorBrushConverter  x:Key="ColorConverter"/>
            <converters:BoolToVisibilityConverter          x:Key="BoolToVis"/>
            <converters:InverseBoolToVisibilityConverter   x:Key="InvBoolToVis"/>
            <converters:NullToVisibilityConverter          x:Key="NullToVis"/>

            <!-- Nav Button Style -->
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#94A3B8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Height" Value="56"/>
                <Setter Property="Margin" Value="16,4,16,4"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="8,0">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#334155"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Tile Button Style -->
            <Style x:Key="TileButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="16">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="0.98" Duration="0:0:0.05"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="0.98" Duration="0:0:0.05"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.05"/>
                                                <DoubleAnimation Storyboard.TargetName="scale" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.05"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <materialDesign:DialogHost IsOpen="{Binding IsNotificationPopupOpen}" Identifier="RootDialog" DialogTheme="Light">
        <materialDesign:DialogHost.DialogContent>
            <!-- Large Notification Dialog -->
            <Border Background="White" CornerRadius="12" Width="600" MinHeight="400" MaxHeight="600" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#3B82F6" CornerRadius="12,12,0,0" Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Recent System Activity" FontSize="20" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" Background="Transparent" BorderThickness="0" Foreground="White" Width="32" Height="32" Padding="0">
                                <materialDesign:PackIcon Kind="Close" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                        <ItemsControl ItemsSource="{Binding Notifications}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Margin="0,0,0,12" Padding="16" Background="#F8FAFC" UniformCornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="White" Width="48" Height="48" CornerRadius="24" VerticalAlignment="Top">
                                                <materialDesign:PackIcon Kind="{Binding Icon}" Foreground="{Binding Color, Converter={StaticResource ColorConverter}}" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" Foreground="#0F172A"/>
                                                <TextBlock Text="{Binding Message}" FontSize="14" Foreground="#475569" TextWrapping="Wrap" Margin="0,4,0,8"/>
                                                <TextBlock Text="{Binding FormattedDate}" FontSize="12" Foreground="#94A3B8"/>
                                            </StackPanel>
                                            <Button Grid.Column="3" Content="View Record" Command="{Binding DataContext.NotificationClickedCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding ViewToken}" Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <TextBlock Grid.Row="1" Text="No recent activity found." Foreground="#94A3B8" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding HasNewNotifications, Converter={StaticResource InvBoolToVis}}"/>
                </Grid>
            </Border>
        </materialDesign:DialogHost.DialogContent>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarOpen}" Value="True">
                                <Setter Property="Width" Value="264"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Sidebar: Col 0, RowSpan 3 -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top: Logo and System Name -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,20,20,10">
                    <Button Command="{Binding OpenAppProfileCommand}"
                            ToolTip="Application Profile"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Border Background="White" CornerRadius="8" Width="40" Height="40">
                            <!-- Binding the logo to SystemPhotoSource or fallback to icon -->
                            <Grid>
                                <materialDesign:PackIcon Kind="BankOutline" Foreground="#0F172A" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding SystemPhotoSource, Converter={StaticResource InvBoolToVis}}"/>
                                <Image Source="{Binding GovPhotoSource}" Stretch="Uniform" Margin="4" Visibility="{Binding SystemPhotoSource, Converter={StaticResource NullToVis}}"/>
                            </Grid>
                        </Border>
                    </Button>
                    <TextBlock Text="GGS" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Middle: Nav Buttons -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0">
                    <StackPanel>
                        <!-- For the items control, group by "Group" property or just flat list -->
                        <TextBlock Text="MODULES" Foreground="white" FontSize="12" FontWeight="SemiBold" Margin="24,16,24,8"/>
                        
                        <ItemsControl ItemsSource="{Binding NavigationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:NavigationItem}">
                                    <Button Style="{StaticResource NavButtonStyle}"
                                            Command="{Binding DataContext.NavigateTileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding ViewToken}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#1F2937" Width="38" Height="38" CornerRadius="10">
                                                <materialDesign:PackIcon Kind="{Binding Icon}" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Name}" VerticalAlignment="Center" FontSize="14" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: Divider, Settings, Logout -->
                <StackPanel Grid.Row="2" Margin="0,0,0,16">
                    <Border Height="1" Background="#273449" Margin="0,8,0,16"/>
                    
                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding OpenSystemsProfileCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#1F2937" Width="38" Height="38" CornerRadius="10">
                                <materialDesign:PackIcon Kind="DatabaseSettings" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="System Profile" VerticalAlignment="Center" FontSize="14"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding LogoutCommand}"
                            CommandParameter="{Binding ElementName=MainWin}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#1F2937" Width="38" Height="38" CornerRadius="10">
                                <materialDesign:PackIcon Kind="Logout" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="Logout" VerticalAlignment="Center" FontSize="14"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top Header Bar — Column 1, Row 0 -->
        <Border Grid.Column="1" Grid.Row="0" Background="#111827" BorderBrush="#1F2937" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left: Hamburger + Org name + Subtitle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ToggleSidebarCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="White"
                            Margin="0,0,16,0"
                            Padding="0"
                            Width="40" Height="40">
                        <materialDesign:PackIcon Kind="Menu" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding GovernanceName}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Governance Management System" FontSize="13" Foreground="white" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Notifications + Username + Role + Avatar -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    
                    <!-- Notification Bell -->
                    <ToggleButton x:Name="NotifToggle" IsChecked="{Binding IsNotificationPopupOpen}" Background="Transparent" BorderThickness="0" Margin="0,0,24,0" Cursor="Hand" Width="40" Height="40" Style="{StaticResource {x:Static ToolBar.ToggleButtonStyleKey}}">
                        <Grid>
                            <materialDesign:PackIcon Kind="BellOutline" Foreground="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border Background="#EF4444" Width="10" Height="10" CornerRadius="5" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,4,0" Visibility="{Binding HasNewNotifications, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </ToggleButton>
                    
                    <!-- Notification Popup -->
                    <!-- Removed popup as it is now a DialogHost at the root -->

                    <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="{Binding CurrentUserName}" Foreground="White" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding CurrentUserRole}" Foreground="#000000" FontSize="12" HorizontalAlignment="Right"/>
                    </StackPanel>
                    
                    <Button Width="40" Height="40" BorderThickness="0" Background="Transparent" Padding="0" Command="{Binding NavigateTileCommand}" CommandParameter="Profile">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3B82F6" CornerRadius="20" ClipToBounds="True">
                                    <Grid>
                                        <Image Source="{Binding ProfilePhotoSource}" Stretch="UniformToFill"/>
                                        <materialDesign:PackIcon Kind="Account" Foreground="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding ProfilePhotoSource, Converter={StaticResource InvBoolToVis}}"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content — Column 1, Row 1 -->
        <Grid Grid.Column="1" Grid.Row="1" Margin="16">
            
            <!-- Dashboard View -->
            <Grid Visibility="{Binding IsShowingDashboard, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Row 0: 4 Colored Tiles -->
                <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource TileButtonStyle}" Background="#3B82F6"
                        Command="{Binding NavigateTileCommand}" CommandParameter="BudgetAllocation">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="ScaleBalance" Width="36" Height="36" Margin="0,0,0,12"/>
                        <TextBlock Text="BUDGET" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Manage allocations" FontSize="13" Opacity="0.8"/>
                    </StackPanel>
                </Button>
                
                <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource TileButtonStyle}" Background="#06B6D4"
                        Command="{Binding NavigateTileCommand}" CommandParameter="Departments">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Domain" Width="36" Height="36" Margin="0,0,0,12"/>
                        <TextBlock Text="DEPARTMENTS" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Internal structures" FontSize="13" Opacity="0.8"/>
                    </StackPanel>
                </Button>
                
                <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource TileButtonStyle}" Background="#F59E0B"
                        Command="{Binding NavigateTileCommand}" CommandParameter="CrsBeneficiary">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="AccountGroup" Width="36" Height="36" Margin="0,0,0,12"/>
                        <TextBlock Text="CITIZENS" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Registry &amp; feedback" FontSize="13" Opacity="0.8"/>
                    </StackPanel>
                </Button>
                
                <Button Grid.Row="0" Grid.Column="3" Style="{StaticResource TileButtonStyle}" Background="#8B5CF6"
                        Command="{Binding NavigateTileCommand}" CommandParameter="Reports">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="FileChart" Width="36" Height="36" Margin="0,0,0,12"/>
                        <TextBlock Text="REPORTS" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Analytics &amp; data" FontSize="13" Opacity="0.8"/>
                    </StackPanel>
                </Button>

                <!-- Column 4, Rows 0-1: Branding Panel -->
                <Border Grid.Row="0" Grid.Column="4" Grid.RowSpan="2" Background="White" CornerRadius="12" Margin="8">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Binding the logo to SystemPhotoSource or fallback to icon -->
                        <Border Background="#F1F5F9" CornerRadius="60" Width="120" Height="120" Margin="0,0,0,16" ClipToBounds="True">
                            <Grid>
                                <materialDesign:PackIcon Kind="ShieldCheck" Foreground="#000000" Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding SystemPhotoSource, Converter={StaticResource InvBoolToVis}}"/>
                                <Image Source="{Binding SystemPhotoSource}" Stretch="Uniform" Margin="8" Visibility="{Binding SystemPhotoSource, Converter={StaticResource NullToVis}}"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="GGS PLATFORM" FontSize="20" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                        <TextBlock Text="Version 2.0" FontSize="14" Foreground="#000000" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Row 1, Columns 0-1: Dark Date/Time & Label -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="#0F172A" CornerRadius="12" Margin="8" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#064E3B" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="SYSTEM READY" Foreground="#34D399" FontSize="12" FontWeight="Bold"/>
                        </Border>
                        
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentDate}" FontSize="28" FontWeight="Light" Foreground="White" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Row 1, Column 2: Users Tile -->
                <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource TileButtonStyle}" Background="#6366F1"
                        Command="{Binding NavigateTileCommand}" CommandParameter="Users">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="AccountGroup" Width="36" Height="36" Margin="0,0,0,12"/>
                        <TextBlock Text="USERS" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Manage accounts" FontSize="13" Opacity="0.8"/>
                    </StackPanel>
                </Button>

                <!-- Row 1, Column 3: Consolidated Tile -->
                <Button Grid.Row="1" Grid.Column="3" Style="{StaticResource TileButtonStyle}" Background="#5E35B1"
                        Command="{Binding NavigateTileCommand}" CommandParameter="ConsolidatedTransactions">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="TableMultiple" Width="36" Height="36" Margin="0,0,0,12"/>
                        <TextBlock Text="CONSOLIDATED" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="All transactions" FontSize="13" Opacity="0.8"/>
                    </StackPanel>
                </Button>

                <!-- Row 2: 4 Colored Tiles -->
                <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource TileButtonStyle}" Background="#EC4899"
                        Command="{Binding NavigateTileCommand}" CommandParameter="Evaluation">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="FileDocumentEdit" Width="36" Height="36" Margin="0,0,0,12"/>
                        <TextBlock Text="EVALUATION" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Performance metrics" FontSize="13" Opacity="0.8"/>
                    </StackPanel>
                </Button>
                
                <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource TileButtonStyle}" Background="#EAB308"
                        Command="{Binding NavigateTileCommand}" CommandParameter="Transactions">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Finance" Width="36" Height="36" Margin="0,0,0,12"/>
                        <TextBlock Text="BUDGET TRANSACTIONS" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                        <TextBlock Text="Financial records" FontSize="13" Opacity="0.8"/>
                    </StackPanel>
                </Button>
                
                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource TileButtonStyle}" Background="#64748B"
                        Command="{Binding NavigateTileCommand}" CommandParameter="Parameters">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CogBox" Width="36" Height="36" Margin="0,0,0,12"/>
                        <TextBlock Text="PARAMETERS" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="System variables" FontSize="13" Opacity="0.8"/>
                    </StackPanel>
                </Button>

                <!-- Row 2, Column 4: Split Settings & Exit Tiles -->
                <Grid Grid.Row="2" Grid.Column="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Style="{StaticResource TileButtonStyle}" Background="#475569" Margin="8,8,4,8"
                            Command="{Binding NavigateTileCommand}" CommandParameter="Settings">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="Cog" Width="36" Height="36" Margin="0,0,0,12"/>
                            <TextBlock Text="SETTINGS" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="System config" FontSize="12" Opacity="0.8"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Grid.Column="1" Style="{StaticResource TileButtonStyle}" Background="#EF4444" Margin="4,8,8,8"
                            Command="{Binding LogoutCommand}" CommandParameter="{Binding ElementName=MainWin}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="Power" Width="36" Height="36" Margin="0,0,0,12"/>
                            <TextBlock Text="EXIT" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="Close app" FontSize="12" Opacity="0.8"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- Active Module View -->
            <Grid Visibility="{Binding IsShowingView, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Breadcrumb for active view -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,16">
                    <Button Background="Transparent" BorderThickness="0"
                            Command="{Binding ShowDashboardCommand}"
                            Margin="0 0 12 0" Foreground="#000000" Height="32" Padding="0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" VerticalAlignment="Center" Margin="0 0 5 0"/>
                            <TextBlock Text="Main" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="›" Foreground="#000000" FontSize="18" VerticalAlignment="Center" Margin="0 0 12 0"/>
                    <TextBlock Text="{Binding CurrentSectionTitle}" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Frame / ContentControl -->
                <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="8">
                    <ContentControl Content="{Binding CurrentView}" Margin="0,2,0,0">
                        <ContentControl.Template>
                            <ControlTemplate TargetType="ContentControl">
                                <Border x:Name="Bd" Opacity="0">
                                    <ContentPresenter/>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22"/>
                                                    <ThicknessAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Margin" From="0,22,0,0" To="0,0,0,0" Duration="0:0:0.28"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                            </ControlTemplate>
                        </ContentControl.Template>
                    </ContentControl>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Footer — Column 1, Row 2 -->
        <Border Grid.Column="1" Grid.Row="2" Background="#111827" Padding="16,8">
            <Grid>
                <!-- Left: System Ready -->
                <Button HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Foreground="#34D399" Padding="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="CheckCircleOutline" Width="16" Height="16" Margin="0,0,8,0"/>
                        <TextBlock Text="SYSTEM READY" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Button>

                <!-- Center-right / Right: Status and Time -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="DATABASE STATUS:" Foreground="white" FontSize="12" Margin="0,0,4,0"/>
                    <TextBlock Text="ONLINE" Foreground="#34D399" FontSize="12" FontWeight="Bold" Margin="0,0,24,0" Visibility="{Binding IsDatabaseConnected, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="OFFLINE" Foreground="#EF4444" FontSize="12" FontWeight="Bold" Margin="0,0,24,0" Visibility="{Binding IsDatabaseConnected, Converter={StaticResource InvBoolToVis}}"/>

                    <Button Command="{Binding NavigateTileCommand}" CommandParameter="Profile"
                            Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,24,0"
                            Foreground="white" Cursor="Hand">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountEdit" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="MY PROFILE" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <materialDesign:PackIcon Kind="ClockOutline" Foreground="White" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding CurrentDate}" Foreground="White" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    </materialDesign:DialogHost>
</Window>
