<UserControl x:Class="GoodGovernanceApp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="850">

    <UserControl.DataContext>
        <viewmodels:SettingsViewModel />
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0 0 0 24">
                <TextBlock Text="System Settings" FontSize="28" FontWeight="Light"/>
                <TextBlock Text="Configure database connections and backup options" 
                           FontSize="13" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 4 0 0"/>
            </StackPanel>

            <!-- GGMS Database Connection -->
            <materialDesign:Card Grid.Row="1" Margin="0 0 0 16" Padding="24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                        <materialDesign:PackIcon Kind="Database" Width="22" Height="22" 
                                                 VerticalAlignment="Center" Margin="0 0 8 0"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <TextBlock Text="GGMS Database Connection" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Preset Buttons -->
                    <TextBlock Text="Quick Presets — fills both GGMS and CRS simultaneously:" FontSize="12"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 10"/>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                        <Grid Margin="0 0 10 0" Width="110">
                            <Button Content="🖥 LOCAL" Command="{Binding PresetLocalCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            <Button Content="🖥 LOCAL" Command="{Binding PresetLocalCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPreset}" Value="LOCAL">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <Grid Margin="0 0 10 0" Width="160">
                            <Button Content="🌐 NETWORK (LAN)" Command="{Binding PresetNetworkCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            <Button Content="🌐 NETWORK (LAN)" Command="{Binding PresetNetworkCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPreset}" Value="NETWORK">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <Grid Width="190">
                            <Button Content="☁ REMOTE (Hostinger)" Command="{Binding PresetRemoteCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            <Button Content="☁ REMOTE (Hostinger)" Command="{Binding PresetRemoteCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPreset}" Value="REMOTE">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- LAN IP Field -->
                    <TextBox materialDesign:HintAssist.Hint="LAN / Network IP (editable — changes per demo)"
                             Text="{Binding LanIp, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0 0 0 16"/>

                    <TextBox materialDesign:HintAssist.Hint="Local Connection String"
                             Text="{Binding LocalConnectionString}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0 0 0 12"/>

                    <TextBox materialDesign:HintAssist.Hint="LAN Connection String"
                             Text="{Binding LanConnectionString}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0 0 0 12"/>

                    <TextBox materialDesign:HintAssist.Hint="Remote Connection String (Hostinger)"
                             Text="{Binding RemoteConnectionString}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0 0 0 0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- CRS Database Connection -->
            <materialDesign:Card Grid.Row="2" Margin="0 0 0 16" Padding="24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                        <materialDesign:PackIcon Kind="DatabaseSearch" Width="22" Height="22" 
                                                 VerticalAlignment="Center" Margin="0 0 8 0"
                                                 Foreground="DarkOrange"/>
                        <TextBlock Text="CRS Database Connection (Read Only)" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="⚠ CRS is read-only for GGMS. All 4 fields are manually editable." 
                               FontSize="12" FontStyle="Italic"
                               Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="CRS Server / IP"
                                 Text="{Binding CrsServer, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Margin="0 0 0 12"/>
                        <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Port"
                                 Text="{Binding CrsPort, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Margin="0 0 0 12"/>
                    </Grid>

                    <TextBox materialDesign:HintAssist.Hint="CRS Database Name"
                             Text="{Binding CrsDatabase, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0 0 0 12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="CRS Username"
                                 Text="{Binding CrsUser, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                        <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="CRS Password"
                                 Text="{Binding CrsPassword, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Test + Save -->
            <materialDesign:Card Grid.Row="3" Margin="0 0 0 16" Padding="24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                        <materialDesign:PackIcon Kind="CheckNetwork" Width="22" Height="22" 
                                                 VerticalAlignment="Center" Margin="0 0 8 0"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <TextBlock Text="Test &amp; Save" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                        <Button Content="🔌 TEST BOTH CONNECTIONS" Command="{Binding TestBothCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" Margin="0 0 12 0"/>
                        <ProgressBar IsIndeterminate="True" Width="24" Height="24"
                                     Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding IsTesting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding GgmsTestResult}" FontSize="13" FontWeight="Medium" Margin="0 0 0 4"
                               Foreground="{DynamicResource MaterialDesignBody}"/>
                    <TextBlock Text="{Binding CrsTestResult}" FontSize="13" FontWeight="Medium" Margin="0 0 0 16"
                               Foreground="{DynamicResource MaterialDesignBody}"/>

                    <Button Content="💾 SAVE SETTINGS (REQUIRES RESTART)"
                            Command="{Binding SaveSettingsCommand}"
                            HorizontalAlignment="Left"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>

                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="Medium"
                               Foreground="Green" Margin="0 12 0 0"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- Backup Configuration                                           -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <materialDesign:Card Grid.Row="4" Margin="0 0 0 16" Padding="24">
            <StackPanel>

                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                    <materialDesign:PackIcon Kind="DatabaseSync" Width="22" Height="22"
                                            VerticalAlignment="Center" Margin="0 0 8 0"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="Automatic Database Backup" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ── Row 1 : Backup Type + Schedule Type ─────────────── -->
                <Grid Margin="0 0 0 16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Backup Type" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 4"/>
                        <ComboBox SelectedItem="{Binding BackupType}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem Content="Full"/>
                            <ComboBoxItem Content="Differential"/>
                            <ComboBoxItem Content="Incremental"/>
                        </ComboBox>
                        <TextBlock FontSize="10" TextWrapping="Wrap" Margin="0 4 0 0"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}">
                            <Run FontWeight="Bold">Full</Run><Run> — schema + all data (baseline).</Run>
                            <LineBreak/>
                            <Run FontWeight="Bold">Differential</Run><Run> — data-only dump (since last full).</Run>
                            <LineBreak/>
                            <Run FontWeight="Bold">Incremental</Run><Run> — data delta since last backup.</Run>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Schedule Type" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 4"/>
                        <ComboBox SelectedItem="{Binding ScheduleType}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem Content="Once"/>
                            <ComboBoxItem Content="Daily"/>
                            <ComboBoxItem Content="Weekly"/>
                            <ComboBoxItem Content="Monthly"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- ── Row 2 : Date (Once) or Day-of-Month (Monthly) ───── -->
                <Grid Margin="0 0 0 16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- DatePicker: shown for "Once" -->
                    <StackPanel Grid.Column="0"
                                Visibility="{Binding IsOnce, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Run Date &amp; Time" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 4"/>
                        <DatePicker SelectedDate="{Binding NextRunTime}"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                    </StackPanel>

                    <!-- Day of month: shown for "Monthly" -->
                    <StackPanel Grid.Column="0"
                                Visibility="{Binding IsMonthlyOrOnce, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!-- only show when Monthly (not Once) -->
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ScheduleType}" Value="Monthly">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Day of Month (1-28)" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 4"/>
                        <TextBox Text="{Binding ScheduleDay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>

                    <!-- Start time (Next run): always visible -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="First / Next Run Date-Time" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 4"/>
                        <DatePicker SelectedDate="{Binding NextRunTime}"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                        <TextBlock Text="(Time-of-day is preserved from the saved value)"
                                   FontSize="10" TextWrapping="Wrap" Margin="0 3 0 0"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    </StackPanel>
                </Grid>

                <!-- ── Row 3 : Backup Folder ──────────────────────────── -->
                <TextBlock Text="Backup Destination Folder" FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 4"/>
                <Grid Margin="0 0 0 16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             materialDesign:HintAssist.Hint="e.g. C:\Backups\GGMS"
                             Text="{Binding BackupFolder, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    <Button Grid.Column="2" Content="📁 Browse"
                            Command="{Binding BrowseBackupFolderCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </Grid>

                <!-- ── Row 4 : mysqldump path ──────────────────────────── -->
                <TextBlock Text="mysqldump.exe Path" FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 4"/>
                <Grid Margin="0 0 0 16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             materialDesign:HintAssist.Hint="e.g. C:\Program Files\MySQL\...\mysqldump.exe"
                             Text="{Binding MySqlDumpPath, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    <Button Grid.Column="2" Content="🔍 Browse"
                            Command="{Binding BrowseMySqlDumpCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </Grid>

                <!-- ── Row 5 : Enable toggle + Save ───────────────────── -->
                <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                    <ToggleButton IsChecked="{Binding IsBackupEnabled}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  VerticalAlignment="Center"/>
                    <TextBlock Text="Enable Automatic Backup" FontSize="14"
                               VerticalAlignment="Center" Margin="12 0 0 0"/>
                </StackPanel>

                <Button Content="💾 SAVE BACKUP SETTINGS"
                        Command="{Binding SaveBackupSettingsCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Left" Margin="0 0 0 20"/>

                <!-- Status / Next run -->
                <TextBlock Text="{Binding BackupStatusMessage}" FontSize="13" FontWeight="Medium"
                           Foreground="Green" Margin="0 0 0 20" TextWrapping="Wrap"/>

                <!-- ── Row 6 : Manual trigger buttons ─────────────────── -->
                <Separator Margin="0 0 0 16"/>
                <TextBlock Text="Manual Backup — run now" FontSize="13" FontWeight="SemiBold"
                           Margin="0 0 0 12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="⚡ FULL BACKUP"
                            Command="{Binding FullBackupCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0 0 10 0"/>
                    <Button Content="⚡ DIFFERENTIAL"
                            Command="{Binding DifferentialBackupCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0 0 10 0"/>
                    <Button Content="⚡ INCREMENTAL"
                            Command="{Binding IncrementalBackupCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </StackPanel>

            </StackPanel>
        </materialDesign:Card>

    </Grid>
</ScrollViewer>
</UserControl>
