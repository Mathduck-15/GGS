<UserControl x:Class="GoodGovernanceApp.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">

    <UserControl.DataContext>
        <viewmodels:SettingsViewModel />
    </UserControl.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="System Settings &amp; Configuration" FontSize="28" FontWeight="Light" Margin="0 0 0 24"/>

        <!-- Database Connection Settings -->
        <materialDesign:Card Grid.Row="1" Margin="0 0 0 16" Padding="16">
            <StackPanel>
                <TextBlock Text="Database Connections" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 16"/>

                <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                    <TextBlock Text="Use Remote (Hostinger) Database:" VerticalAlignment="Center" Margin="0 0 16 0"/>
                    <ToggleButton IsChecked="{Binding UseRemoteDatabase}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                </StackPanel>

                <TextBox materialDesign:HintAssist.Hint="Local Connection String (MySQL)" 
                         Text="{Binding LocalConnectionString}" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 16" />

                <TextBox materialDesign:HintAssist.Hint="Remote Connection String (Hostinger MySQL)" 
                         Text="{Binding RemoteConnectionString}" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 24" />

                <Button Content="SAVE SETTINGS (REQUIRES RESTART)" Command="{Binding SaveSettingsCommand}" 
                        HorizontalAlignment="Left" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource PrimaryHueMidBrush}" />
            </StackPanel>
        </materialDesign:Card>

        <!-- Backup Settings -->
        <materialDesign:Card Grid.Row="2" Margin="0 0 0 16" Padding="16">
            <StackPanel>
                <TextBlock Text="Database Backup" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 16"/>
                <TextBlock Text="Specify the path to 'mysqldump.exe' (usually in MySQL Server/bin)." FontStyle="Italic" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 8"/>

                <TextBox materialDesign:HintAssist.Hint="mysqldump.exe Path" 
                         Text="{Binding MySqlDumpPath}" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 16" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="RUN FULL BACKUP" Command="{Binding FullBackupCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0 0 16 0" />
                            
                    <Button Content="RUN DIFFERENTIAL BACKUP" Command="{Binding DifferentialBackupCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0 0 16 0" />

                    <Button Content="RUN INCREMENTAL BACKUP" Command="{Binding IncrementalBackupCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <!-- Status Message -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" FontSize="16" Foreground="Green" FontWeight="Medium" VerticalAlignment="Top"/>
        
    </Grid>
</UserControl>
