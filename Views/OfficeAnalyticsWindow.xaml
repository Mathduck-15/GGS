<Window x:Class="GoodGovernanceApp.Views.OfficeAnalyticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Office Analytics" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading overlay -->
        <ProgressBar IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                     VerticalAlignment="Top" Grid.RowSpan="3" Panel.ZIndex="10"/>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Domain" Width="48" Height="48" Foreground="#0284C7"/>
                <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Office Analytics Report" FontSize="14" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding OfficeName}" FontSize="28" Foreground="#0F172A" FontWeight="Bold"/>
                    <TextBlock Text="{Binding OfficeCode, StringFormat='Office Code: {0}'}" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- KPI Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Total Trans -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Total Transactions" Foreground="#64748B" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalTransactions}" Foreground="#0F172A" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Consolidated Spending -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="10,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Consolidated Spent" Foreground="#64748B" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ConsolidatedAmount, StringFormat=C2}" Foreground="#059669" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 3: Dept Spending -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20" Margin="10,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Dept Budget Spent" Foreground="#64748B" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding DepartmentBudgetAmount, StringFormat=C2}" Foreground="#D97706" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 4: Total Amount -->
            <Border Grid.Column="3" Background="White" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Overall Spent" Foreground="#64748B" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat=C2}" Foreground="#DB2777" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Charts and List -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Charts Column -->
            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Amount by Type" Foreground="#0F172A" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <lvc:PieChart Series="{Binding TypeBreakdownSeries}" LegendLocation="Bottom" Height="150" InnerRadius="40"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Count by Source" Foreground="#0F172A" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <lvc:PieChart Series="{Binding StatusBreakdownSeries}" LegendLocation="Bottom" Height="150" InnerRadius="0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Transactions Grid -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Office Transactions List" Foreground="#0F172A" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding OfficeTransactions}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="Transparent"
                              RowBackground="White"
                              AlternatingRowBackground="#F1F5F9"
                              Foreground="#334155"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E2E8F0"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate, StringFormat=d}" Width="100"/>
                            <DataGridTextColumn Header="Project" Binding="{Binding ProjectCode}" Width="120"/>
                            <DataGridTextColumn Header="Beneficiary" Binding="{Binding FullName}" Width="150"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="100"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C2}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
