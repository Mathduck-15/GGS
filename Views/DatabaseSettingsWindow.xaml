<Window x:Class="GoodGovernanceApp.Views.DatabaseSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
        Title="Database Connection Settings" Height="780" Width="640"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.DataContext>
        <viewmodels:SettingsViewModel />
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0 0 0 16">
            <TextBlock Text="Database Configuration" FontSize="24" FontWeight="Light"/>
            <TextBlock Text="Select a preset or manually enter your connection details." 
                       FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 4 0 0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- GGMS Connection -->
                <materialDesign:Card Margin="0 0 0 16" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                            <materialDesign:PackIcon Kind="Database" Width="22" Height="22" 
                                                     VerticalAlignment="Center" Margin="0 0 8 0"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="GGMS Database" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Preset Buttons -->
                        <TextBlock Text="Quick Presets — fills both GGMS and CRS simultaneously:" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 0 0 10"/>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                            <Button Content="🖥 LOCAL" Command="{Binding PresetLocalCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0 0 8 0" Width="100"/>
                            <Button Content="🌐 NETWORK" Command="{Binding PresetNetworkCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0 0 8 0" Width="130"/>
                            <Button Content="☁ REMOTE" Command="{Binding PresetRemoteCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" Width="130"/>
                        </StackPanel>

                        

                    </StackPanel>
                </materialDesign:Card>

                <!-- CRS Connection -->
               

                <!-- Test Connection -->
                <materialDesign:Card Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                            <materialDesign:PackIcon Kind="CheckNetwork" Width="20" Height="20" 
                                                     VerticalAlignment="Center" Margin="0 0 8 0"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Test Connections" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                            <Button x:Name="TestConnectionBtn" Content="🔌 TEST BOTH"
                                    Command="{Binding TestBothCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0 0 12 0"/>
                            <ProgressBar x:Name="TestProgress" IsIndeterminate="True"
                                         Width="24" Height="24"
                                         Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         VerticalAlignment="Center"
                                         Visibility="{Binding IsTesting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding GgmsTestResult}" FontSize="13" FontWeight="Medium" Margin="0 0 0 4"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                        <TextBlock Text="{Binding CrsTestResult}" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 16 0 0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="0 0 16 0" Foreground="Green"/>
            <Button Content="SAVE &amp; CLOSE" Command="{Binding SaveSettingsCommand}" Click="SaveButton_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>
