<Window x:Class="GoodGovernanceApp.Views.DatabaseSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
        Title="Database Connection Settings" Height="540" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignFont}">
    
    <Window.DataContext>
        <viewmodels:SettingsViewModel />
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Database Configuration" FontSize="24" FontWeight="Light" Margin="0 0 0 16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <materialDesign:Card Margin="0 0 0 16" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Connections" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 12"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                            <TextBlock Text="Use Remote Database:" VerticalAlignment="Center" Margin="0 0 16 0"/>
                            <ToggleButton IsChecked="{Binding UseRemoteDatabase}" Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                        </StackPanel>

                        <TextBox materialDesign:HintAssist.Hint="Local Connection String" 
                                 Text="{Binding LocalConnectionString}" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 12" />

                        <TextBox materialDesign:HintAssist.Hint="Remote Connection String" 
                                 Text="{Binding RemoteConnectionString}" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0 0 0 16" />

                        <!-- Test Connection Row -->
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 4">
                            <Button x:Name="TestConnectionBtn" Content="🔌 TEST REMOTE CONNECTION"
                                    Click="TestConnection_Click"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0 0 12 0"/>
                            <ProgressBar x:Name="TestProgress" IsIndeterminate="True"
                                         Width="24" Height="24"
                                         Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         Visibility="Collapsed" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Connection Status Result -->
                        <Border x:Name="StatusPanel" Visibility="Collapsed" 
                                CornerRadius="4" Padding="12 8" Margin="0 8 0 0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="StatusIcon" FontSize="16" Margin="0 0 8 0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="380"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Padding="16">
                    <StackPanel>
                        <TextBlock Text="Backup Utility" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 12"/>
                        <TextBox materialDesign:HintAssist.Hint="mysqldump.exe Path" 
                                 Text="{Binding MySqlDumpPath}" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 16 0 0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="0 0 16 0" Foreground="Green"/>
            <Button Content="SAVE &amp; CLOSE" Command="{Binding SaveSettingsCommand}" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>

