<UserControl x:Class="GoodGovernanceApp.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:converters="clr-namespace:GoodGovernanceApp.Converters"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.DataContext>
        <viewmodels:ReportsViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- selector bar -->
            <RowDefinition Height="*"/>     <!-- content -->
        </Grid.RowDefinitions>

        <!-- ── Page Header ────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Reports &amp; Analytics"
                       FontSize="28" FontWeight="Light" Foreground="#1E293B"/>
            <TextBlock Text="Select a report type to view data and charts"
                       FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── Selector Bar ───────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="White" CornerRadius="12"
                Padding="16,12" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          materialDesign:HintAssist.Hint="Select Report Type"
                          ItemsSource="{Binding ReportTypes}"
                          SelectedItem="{Binding SelectedReportType}"
                          Width="340" HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <Button Grid.Column="1" Content="REFRESH"
                        Command="{Binding GenerateReportCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="12,0,8,0" VerticalAlignment="Center"/>

                <Button Grid.Column="2" Content="EXPORT"
                        Command="{Binding PrintExportCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             CONTENT AREA  — one panel per report type, shown by visibility
        ══════════════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  1. FINANCIAL OVERVIEW  (moved from DashboardView)      │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsFinancialOverviewVisible, Converter={StaticResource BoolToVis}}">

                    <!-- KPI cards -->
                    <UniformGrid Columns="4" Rows="1" Margin="0,0,0,16">
                        <!-- Total Budget -->
                        <Border Background="#0F172A" CornerRadius="12" Margin="0,0,8,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="BankOutline" Foreground="#60A5FA" Width="28" Height="28"/>
                                <TextBlock Text="Total Budget" Foreground="#94A3B8" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding TotalBudget, StringFormat='₱{0:N2}'}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Expenses -->
                        <Border Background="#7F1D1D" CornerRadius="12" Margin="4,0,4,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="TrendingDown" Foreground="#FCA5A5" Width="28" Height="28"/>
                                <TextBlock Text="Total Expenses" Foreground="#FCA5A5" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding TotalExpenses, StringFormat='₱{0:N2}'}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Active Users -->
                        <Border Background="#064E3B" CornerRadius="12" Margin="4,0,4,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AccountGroupOutline" Foreground="#6EE7B7" Width="28" Height="28"/>
                                <TextBlock Text="Active Users" Foreground="#6EE7B7" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding ActiveUsers}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Projects -->
                        <Border Background="#1E1B4B" CornerRadius="12" Margin="8,0,0,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="FolderMultipleOutline" Foreground="#A5B4FC" Width="28" Height="28"/>
                                <TextBlock Text="Total Projects" Foreground="#A5B4FC" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding TotalProjects}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Charts row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Dept Budget Distribution pie -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12"
                                Margin="0,0,8,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Budget Distribution by Office"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"
                                           Margin="0,0,0,12"/>
                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding DeptBudgetSeries}"
                                              LegendLocation="Bottom"
                                              Hoverable="True"/>
                            </Grid>
                        </Border>

                        <!-- Project Budget pie -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12"
                                Margin="8,0,0,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Budget by Project (Current Year)"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"
                                           Margin="0,0,0,12"/>
                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding ProjectBudgetSeries}"
                                              LegendLocation="Bottom"
                                              Hoverable="True"/>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  2. CONSOLIDATED TRANSACTIONS ANALYTICS                 │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsConsolidatedAnalyticsVisible, Converter={StaticResource BoolToVis}}">

                    <!-- KPI cards -->
                    <UniformGrid Columns="3" Rows="1" Margin="0,0,0,16">
                        <Border Background="#1E3A5F" CornerRadius="12" Margin="0,0,8,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="TableMultiple" Foreground="#93C5FD" Width="28" Height="28"/>
                                <TextBlock Text="Total Records" Foreground="#93C5FD" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding ConsolidatedTotalCount}"
                                           Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#14532D" CornerRadius="12" Margin="4,0,4,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="CurrencyPhp" Foreground="#86EFAC" Width="28" Height="28"/>
                                <TextBlock Text="Total Amount" Foreground="#86EFAC" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding ConsolidatedTotalAmount, StringFormat='₱{0:N2}'}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#3B0764" CornerRadius="12" Margin="8,0,0,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="ChartBar" Foreground="#D8B4FE" Width="28" Height="28"/>
                                <TextBlock Text="Avg per Record" Foreground="#D8B4FE" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding ConsolidatedAvgAmount, StringFormat='₱{0:N2}'}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Charts row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Transaction type pie -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12"
                                Margin="0,0,8,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="By Transaction Type"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"
                                           Margin="0,0,0,12"/>
                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding ConsolidatedTypeSeries}"
                                              LegendLocation="Bottom" Hoverable="True"/>
                            </Grid>
                        </Border>

                        <!-- Monthly trend bar chart -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12"
                                Margin="8,0,0,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Monthly Trend"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"
                                           Margin="0,0,0,12"/>
                                <lvc:CartesianChart Grid.Row="1"
                                                    Series="{Binding ConsolidatedMonthlySeries}">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding ConsolidatedMonthlyLabels}"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis LabelFormatter="{Binding CurrencyFormatter}"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  3. CRS BENEFICIARY ANALYTICS                           │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsCrsAnalyticsVisible, Converter={StaticResource BoolToVis}}">

                    <!-- KPI cards -->
                    <UniformGrid Columns="3" Rows="1" Margin="0,0,0,16">
                        <Border Background="#0F172A" CornerRadius="12" Margin="0,0,8,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AccountMultiple" Foreground="#60A5FA" Width="28" Height="28"/>
                                <TextBlock Text="Total Beneficiaries" Foreground="#60A5FA" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding CrsTotalCount}"
                                           Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#7C2D12" CornerRadius="12" Margin="4,0,4,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Wheelchair" Foreground="#FED7AA" Width="28" Height="28"/>
                                <TextBlock Text="PWD" Foreground="#FED7AA" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding CrsPwdCount}"
                                           Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E3A5F" CornerRadius="12" Margin="8,0,0,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="HumanCane" Foreground="#93C5FD" Width="28" Height="28"/>
                                <TextBlock Text="Senior Citizens" Foreground="#93C5FD" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding CrsSeniorCount}"
                                           Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Charts row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Gender pie -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12"
                                Margin="0,0,8,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Gender Distribution"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"
                                           Margin="0,0,0,12"/>
                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding CrsGenderSeries}"
                                              LegendLocation="Bottom" Hoverable="True"/>
                            </Grid>
                        </Border>

                        <!-- Age group histogram -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12"
                                Margin="8,0,0,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Age Group Distribution"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"
                                           Margin="0,0,0,12"/>
                                <lvc:CartesianChart Grid.Row="1"
                                                    Series="{Binding CrsAgeGroupSeries}">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding CrsAgeGroupLabels}" Title="Age Group"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Count"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  4–9. EXISTING TABULAR REPORTS                          │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <Border Background="White" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsUserActivityLogVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding UserActivityLogs}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat={}{0:G}}" Width="160"/>
                            <DataGridTextColumn Header="User"      Binding="{Binding User.Name}"   Width="140"/>
                            <DataGridTextColumn Header="Action"    Binding="{Binding Action}"       Width="160"/>
                            <DataGridTextColumn Header="Details"   Binding="{Binding Details}"      Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsBudgetSummaryVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding BudgetSummaries}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category"          Binding="{Binding CategoryName}"                                    Width="*"/>
                            <DataGridTextColumn Header="Total Budget"       Binding="{Binding TotalBudget,      StringFormat={}{0:C}}"          Width="160"/>
                            <DataGridTextColumn Header="Total Expenses"     Binding="{Binding TotalExpenses,    StringFormat={}{0:C}}"          Width="160"/>
                            <DataGridTextColumn Header="Remaining Balance"  Binding="{Binding RemainingBalance, StringFormat={}{0:C}}"          Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsTransactionHistoryVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding TransactionHistory}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date"         Binding="{Binding Date,            StringFormat={}{0:d}}"  Width="100"/>
                            <DataGridTextColumn Header="Type"         Binding="{Binding TransactionType}"                        Width="140"/>
                            <DataGridTextColumn Header="Amount"       Binding="{Binding Amount,          StringFormat={}{0:C}}"  Width="120"/>
                            <DataGridTextColumn Header="Voucher"      Binding="{Binding VoucherCode}"                            Width="110"/>
                            <DataGridTextColumn Header="Project Code" Binding="{Binding ProjectCode}"                            Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsParametersListVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding ParametersList}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Parameter Name" Binding="{Binding Name}"        Width="200"/>
                            <DataGridTextColumn Header="Current Value"  Binding="{Binding Value}"       Width="180"/>
                            <DataGridTextColumn Header="Description"    Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsDepartmentalBudgetVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding DepartmentalBudgets}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Department"      Binding="{Binding DepartmentName}"                    Width="*"/>
                            <DataGridTextColumn Header="Year"            Binding="{Binding Year}"                              Width="80"/>
                            <DataGridTextColumn Header="Allocated"       Binding="{Binding Allocated, StringFormat={}{0:C}}"   Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsSystemOverviewVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="1" Opacity="0.3"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding SystemOverview}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="42" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Metric" Binding="{Binding Metric}" Width="300"/>
                            <DataGridTextColumn Header="Value"  Binding="{Binding Value}"  Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
