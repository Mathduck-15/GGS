<UserControl x:Class="GoodGovernanceApp.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:converters="clr-namespace:GoodGovernanceApp.Converters"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.DataContext>
        <viewmodels:ReportsViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- selector bar -->
            <RowDefinition Height="*"/>     <!-- content -->
        </Grid.RowDefinitions>

        <!-- ── Page Header ────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Reports &amp; Analytics"
                       FontSize="28" FontWeight="Light" Foreground="#000000"/>
            <TextBlock Text="Select a report type to view data and charts"
                       FontSize="13" Foreground="#8DB355" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── Selector Bar ───────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="12"
                Padding="16,12" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          materialDesign:HintAssist.Hint="Select Report Type"
                          ItemsSource="{Binding ReportTypes}"
                          SelectedItem="{Binding SelectedReportType}"
                          Width="340" HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <Button Grid.Column="1" Content="REFRESH"
                        Command="{Binding GenerateReportCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="12,0,8,0" VerticalAlignment="Center"/>

                <Button Grid.Column="2" Content="EXPORT"
                        Command="{Binding PrintExportCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             CONTENT AREA  — one panel per report type, shown by visibility
        ══════════════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  1. FINANCIAL OVERVIEW  (moved from DashboardView)      │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsFinancialOverviewVisible, Converter={StaticResource BoolToVis}}">

                    <!-- KPI cards -->
                    <UniformGrid Columns="4" Rows="1" Margin="0,0,0,16">
                        <!-- Total Budget -->
                        <Border Background="#000000" CornerRadius="12" Margin="0,0,8,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="BankOutline" Foreground="#8DB355" Width="28" Height="28"/>
                                <TextBlock Text="Total Budget" Foreground="#8DB355" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding TotalBudget, StringFormat='₱{0:N2}'}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Expenses -->
                        <Border Background="#D90000" CornerRadius="12" Margin="4,0,4,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="TrendingDown" Foreground="White" Width="28" Height="28"/>
                                <TextBlock Text="Total Expenses" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding TotalExpenses, StringFormat='₱{0:N2}'}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Active Users -->
                        <Border Background="#000000" CornerRadius="12" Margin="4,0,4,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AccountGroupOutline" Foreground="#8DB355" Width="28" Height="28"/>
                                <TextBlock Text="Active Users" Foreground="#8DB355" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding ActiveUsers}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Projects -->
                        <Border Background="#000000" CornerRadius="12" Margin="8,0,0,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="FolderMultipleOutline" Foreground="White" Width="28" Height="28"/>
                                <TextBlock Text="Total Projects" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding TotalProjects}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Charts row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Dept Budget Distribution pie -->
                        <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="12"
                                Margin="0,0,8,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Budget Distribution by Office"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#000000"
                                           Margin="0,0,0,12"/>
                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding DeptBudgetSeries}"
                                              LegendLocation="Bottom"
                                              Hoverable="True"/>
                            </Grid>
                        </Border>

                        <!-- Project Budget pie -->
                        <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="12"
                                Margin="8,0,0,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Budget by Project (Current Year)"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#000000"
                                           Margin="0,0,0,12"/>
                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding ProjectBudgetSeries}"
                                              LegendLocation="Bottom"
                                              Hoverable="True"/>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  2. CONSOLIDATED TRANSACTIONS ANALYTICS                 │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsConsolidatedAnalyticsVisible, Converter={StaticResource BoolToVis}}">

                    <!-- KPI cards -->
                    <UniformGrid Columns="3" Rows="1" Margin="0,0,0,16">
                        <Border Background="#000000" CornerRadius="12" Margin="0,0,8,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="TableMultiple" Foreground="White" Width="28" Height="28"/>
                                <TextBlock Text="Total Records" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding ConsolidatedTotalCount}"
                                           Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#000000" CornerRadius="12" Margin="4,0,4,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="CurrencyPhp" Foreground="#8DB355" Width="28" Height="28"/>
                                <TextBlock Text="Total Amount" Foreground="#8DB355" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding ConsolidatedTotalAmount, StringFormat='₱{0:N2}'}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#000000" CornerRadius="12" Margin="8,0,0,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="ChartBar" Foreground="White" Width="28" Height="28"/>
                                <TextBlock Text="Avg per Record" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding ConsolidatedAvgAmount, StringFormat='₱{0:N2}'}"
                                           Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Charts row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Transaction type pie -->
                        <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="12"
                                Margin="0,0,8,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="By Transaction Type"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#000000"
                                           Margin="0,0,0,12"/>
                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding ConsolidatedTypeSeries}"
                                              LegendLocation="Bottom" Hoverable="True"/>
                            </Grid>
                        </Border>

                        <!-- Monthly trend bar chart -->
                        <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="12"
                                Margin="8,0,0,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Monthly Trend"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#000000"
                                           Margin="0,0,0,12"/>
                                <lvc:CartesianChart Grid.Row="1"
                                                    Series="{Binding ConsolidatedMonthlySeries}">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding ConsolidatedMonthlyLabels}"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis LabelFormatter="{Binding CurrencyFormatter}"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  3. CRS BENEFICIARY ANALYTICS                           │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsCrsAnalyticsVisible, Converter={StaticResource BoolToVis}}">

                    <!-- KPI cards -->
                    <UniformGrid Columns="3" Rows="1" Margin="0,0,0,16">
                        <Border Background="#000000" CornerRadius="12" Margin="0,0,8,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AccountMultiple" Foreground="#8DB355" Width="28" Height="28"/>
                                <TextBlock Text="Total Beneficiaries" Foreground="#8DB355" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding CrsTotalCount}"
                                           Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#D90000" CornerRadius="12" Margin="4,0,4,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Wheelchair" Foreground="White" Width="28" Height="28"/>
                                <TextBlock Text="PWD" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding CrsPwdCount}"
                                           Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#000000" CornerRadius="12" Margin="8,0,0,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="HumanCane" Foreground="White" Width="28" Height="28"/>
                                <TextBlock Text="Senior Citizens" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding CrsSeniorCount}"
                                           Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Charts row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Gender pie -->
                        <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="12"
                                Margin="0,0,8,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Gender Distribution"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#000000"
                                           Margin="0,0,0,12"/>
                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding CrsGenderSeries}"
                                              LegendLocation="Bottom" Hoverable="True"/>
                            </Grid>
                        </Border>

                        <!-- Age group histogram -->
                        <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="12"
                                Margin="8,0,0,0" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Age Group Distribution"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#000000"
                                           Margin="0,0,0,12"/>
                                <lvc:CartesianChart Grid.Row="1"
                                                    Series="{Binding CrsAgeGroupSeries}">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding CrsAgeGroupLabels}" Title="Age Group"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Count"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  4–9. EXISTING TABULAR REPORTS                          │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <Border Background="#FFFFFF" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsUserActivityLogVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding UserActivityLogs}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat={}{0:G}}" Width="160"/>
                            <DataGridTextColumn Header="User"      Binding="{Binding User.Name}"   Width="140"/>
                            <DataGridTextColumn Header="Action"    Binding="{Binding Action}"       Width="160"/>
                            <DataGridTextColumn Header="Details"   Binding="{Binding Details}"      Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Background="#FFFFFF" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsBudgetSummaryVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding BudgetSummaries}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category"          Binding="{Binding CategoryName}"                                    Width="*"/>
                            <DataGridTextColumn Header="Total Budget"       Binding="{Binding TotalBudget,      StringFormat={}{0:C}}"          Width="160"/>
                            <DataGridTextColumn Header="Total Expenses"     Binding="{Binding TotalExpenses,    StringFormat={}{0:C}}"          Width="160"/>
                            <DataGridTextColumn Header="Remaining Balance"  Binding="{Binding RemainingBalance, StringFormat={}{0:C}}"          Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Background="#FFFFFF" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsTransactionHistoryVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding TransactionHistory}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date"         Binding="{Binding Date,            StringFormat={}{0:d}}"  Width="100"/>
                            <DataGridTextColumn Header="Type"         Binding="{Binding TransactionType}"                        Width="140"/>
                            <DataGridTextColumn Header="Amount"       Binding="{Binding Amount,          StringFormat={}{0:C}}"  Width="120"/>
                            <DataGridTextColumn Header="Voucher"      Binding="{Binding VoucherCode}"                            Width="110"/>
                            <DataGridTextColumn Header="Project Code" Binding="{Binding ProjectCode}"                            Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Background="#FFFFFF" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsParametersListVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding ParametersList}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Parameter Name" Binding="{Binding Name}"        Width="200"/>
                            <DataGridTextColumn Header="Current Value"  Binding="{Binding Value}"       Width="180"/>
                            <DataGridTextColumn Header="Description"    Binding="{Binding Description}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Background="#FFFFFF" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsDepartmentalBudgetVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding DepartmentalBudgets}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Department"      Binding="{Binding DepartmentName}"                    Width="*"/>
                            <DataGridTextColumn Header="Year"            Binding="{Binding Year}"                              Width="80"/>
                            <DataGridTextColumn Header="Allocated"       Binding="{Binding Allocated, StringFormat={}{0:C}}"   Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Background="#FFFFFF" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsSystemOverviewVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                    <DataGrid ItemsSource="{Binding SystemOverview}" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" RowHeight="42" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Metric" Binding="{Binding Metric}" Width="300"/>
                            <DataGridTextColumn Header="Value"  Binding="{Binding Value}"  Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>


                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  10. BENEFICIARIES PER PROJECT                          │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsBeneficiariesPerProjectVisible, Converter={StaticResource BoolToVis}}">

                    <!-- Bar chart -->
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="260"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Beneficiaries per Project" FontSize="16" FontWeight="SemiBold" Foreground="#000000" Margin="0,0,0,12"/>
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding BppBarSeries}">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding BppBarLabels}" Title="Project"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Beneficiaries"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>

                    <!-- Table -->
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="16">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <DataGrid ItemsSource="{Binding BeneficiariesPerProject}" AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Project Name"     Binding="{Binding ProjectName}"                                  Width="*"/>
                                <DataGridTextColumn Header="Project Code"     Binding="{Binding ProjectCode}"                                  Width="140"/>
                                <DataGridTextColumn Header="Beneficiaries"    Binding="{Binding BeneficiaryCount}"                             Width="120"/>
                                <DataGridTextColumn Header="Transactions"     Binding="{Binding TransactionCount}"                             Width="110"/>
                                <DataGridTextColumn Header="Total Amount"     Binding="{Binding TotalAmount, StringFormat={}{0:C}}"            Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  11. INDIVIDUAL BENEFICIARIES SERVICES RECEIVED         │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <Border Background="#FFFFFF" CornerRadius="12" Padding="16"
                        Visibility="{Binding IsIndividualBeneficiariesVisible, Converter={StaticResource BoolToVis}}">
                    <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Individual Beneficiaries — Services Received"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#000000" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding IndividualBeneficiaries}" AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Beneficiary ID"    Binding="{Binding BeneficiaryId}"                                Width="140"/>
                                <DataGridTextColumn Header="Full Name"         Binding="{Binding FullName}"                                     Width="*"/>
                                <DataGridTextColumn Header="Service Types"     Binding="{Binding ServicesReceived}"                             Width="110"/>
                                <DataGridTextColumn Header="Transactions"      Binding="{Binding TotalTransactions}"                            Width="110"/>
                                <DataGridTextColumn Header="Total Amount"      Binding="{Binding TotalAmount, StringFormat={}{0:C}}"            Width="140"/>
                                <DataGridTextColumn Header="Last Service"      Binding="{Binding LastServiceDate, StringFormat={}{0:d}}"        Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  12. BUDGET UTILIZATION REPORT                          │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsBudgetUtilizationVisible, Converter={StaticResource BoolToVis}}">

                    <!-- Stacked bar chart -->
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="280"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Budget vs Spent per Project" FontSize="16" FontWeight="SemiBold" Foreground="#000000" Margin="0,0,0,12"/>
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding BudgetUtilSeries}">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding BudgetUtilLabels}" Title="Project"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis LabelFormatter="{Binding CurrencyFormatter}" Title="Amount"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>

                    <!-- Table -->
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="16">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <DataGrid ItemsSource="{Binding BudgetUtilization}" AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Project Name"     Binding="{Binding ProjectName}"                                  Width="*"/>
                                <DataGridTextColumn Header="Project Code"     Binding="{Binding ProjectCode}"                                  Width="140"/>
                                <DataGridTextColumn Header="Budget"           Binding="{Binding Budget,    StringFormat={}{0:C}}"              Width="130"/>
                                <DataGridTextColumn Header="Spent"            Binding="{Binding Spent,     StringFormat={}{0:C}}"              Width="130"/>
                                <DataGridTextColumn Header="Remaining"        Binding="{Binding Remaining, StringFormat={}{0:C}}"              Width="130"/>
                                <DataGridTextColumn Header="Utilization %"    Binding="{Binding UtilizationPct, StringFormat={}{0:F1}%}"      Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  13. PROJECT IMPLEMENTATION STATUS REPORT               │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsProjectStatusVisible, Converter={StaticResource BoolToVis}}">

                    <!-- KPI + pie -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                            <Border Background="#000000" CornerRadius="12" Padding="24,16" Margin="0,0,8,0">
                                <StackPanel>
                                    <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#8DB355" Width="28" Height="28"/>
                                    <TextBlock Text="Active Projects" Foreground="#8DB355" FontSize="13" Margin="0,8,0,4"/>
                                    <TextBlock Text="{Binding ActiveProjectCount}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#D90000" CornerRadius="12" Padding="24,16">
                                <StackPanel>
                                    <materialDesign:PackIcon Kind="ArchiveOutline" Foreground="White" Width="28" Height="28"/>
                                    <TextBlock Text="Closed Projects" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                    <TextBlock Text="{Binding ClosedProjectCount}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="12" Padding="20" Height="200">
                            <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                            <lvc:PieChart Series="{Binding ProjectStatusSeries}" LegendLocation="Right" Hoverable="True"/>
                        </Border>
                    </Grid>

                    <!-- Table -->
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="16">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <DataGrid ItemsSource="{Binding ProjectStatusRows}" AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Project Name"    Binding="{Binding ProjectName}"                                  Width="*"/>
                                <DataGridTextColumn Header="Office"          Binding="{Binding Office}"                                       Width="120"/>
                                <DataGridTextColumn Header="Status"          Binding="{Binding Status}"                                       Width="90"/>
                                <DataGridTextColumn Header="Budget"          Binding="{Binding Budget,    StringFormat={}{0:C}}"              Width="130"/>
                                <DataGridTextColumn Header="Spent"           Binding="{Binding Spent,     StringFormat={}{0:C}}"              Width="130"/>
                                <DataGridTextColumn Header="Remaining"       Binding="{Binding Remaining, StringFormat={}{0:C}}"              Width="130"/>
                                <DataGridTextColumn Header="Utilization %"   Binding="{Binding UtilizationPct, StringFormat={}{0:F1}%}"      Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  14. PUBLIC SERVICE DELIVERY REPORT                     │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsPublicServiceDeliveryVisible, Converter={StaticResource BoolToVis}}">

                    <!-- Bar chart -->
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="260"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Beneficiaries Served per Office" FontSize="16" FontWeight="SemiBold" Foreground="#000000" Margin="0,0,0,12"/>
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding PublicServiceSeries}">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding PublicServiceLabels}" Title="Office"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Beneficiaries Served"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>

                    <!-- Table -->
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="16">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <DataGrid ItemsSource="{Binding PublicServiceRows}" AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Office Name"        Binding="{Binding OfficeName}"                                Width="*"/>
                                <DataGridTextColumn Header="Beneficiaries"      Binding="{Binding BeneficiaryCount}"                         Width="120"/>
                                <DataGridTextColumn Header="Transactions"       Binding="{Binding TransactionCount}"                         Width="110"/>
                                <DataGridTextColumn Header="Total Amount"       Binding="{Binding TotalAmount, StringFormat={}{0:C}}"        Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  15. CITIZEN FEEDBACK SUMMARY REPORT                    │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsCitizenFeedbackVisible, Converter={StaticResource BoolToVis}}">

                    <!-- KPI cards -->
                    <UniformGrid Columns="2" Rows="1" Margin="0,0,0,16">
                        <Border Background="#000000" CornerRadius="12" Margin="0,0,8,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="StarOutline" Foreground="White" Width="28" Height="28"/>
                                <TextBlock Text="Total Evaluations" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding TotalFeedbackCount}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#000000" CornerRadius="12" Margin="8,0,0,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="ChartLine" Foreground="White" Width="28" Height="28"/>
                                <TextBlock Text="Average Score" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding AvgFeedbackScore, StringFormat={}{0:F1} / 100}" Foreground="White" FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Score distribution bar chart -->
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="240"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Score Distribution" FontSize="16" FontWeight="SemiBold" Foreground="#000000" Margin="0,0,0,12"/>
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding FeedbackScoreSeries}">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding FeedbackScoreLabels}" Title="Rating Band"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Count"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>

                    <!-- Table -->
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="16">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <DataGrid ItemsSource="{Binding CitizenFeedbackRows}" AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date"       Binding="{Binding Date}"      Width="120"/>
                                <DataGridTextColumn Header="Evaluator"  Binding="{Binding Evaluator}" Width="160"/>
                                <DataGridTextColumn Header="File"       Binding="{Binding File}"      Width="180"/>
                                <DataGridTextColumn Header="Score"      Binding="{Binding Score}"     Width="70"/>
                                <DataGridTextColumn Header="Rating"     Binding="{Binding Rating}"    Width="90"/>
                                <DataGridTextColumn Header="Comments"   Binding="{Binding Comments}"  Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>

                <!-- ┌─────────────────────────────────────────────────────────┐ -->
                <!-- │  16. BENEFICIARY MASTER LIST                            │ -->
                <!-- └─────────────────────────────────────────────────────────┘ -->
                <StackPanel Visibility="{Binding IsBeneficiaryMasterListVisible, Converter={StaticResource BoolToVis}}">

                    <!-- KPI row -->
                    <UniformGrid Columns="4" Rows="1" Margin="0,0,0,16">
                        <!-- Total Beneficiaries -->
                        <Border Background="#000000" CornerRadius="12" Margin="0,0,8,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="AccountGroupOutline" Foreground="#8DB355" Width="28" Height="28"/>
                                <TextBlock Text="Total Beneficiaries" Foreground="#8DB355" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding BmlTotalBeneficiaries}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Total Amount Received -->
                        <Border Background="#000000" CornerRadius="12" Margin="4,0,4,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="CashMultiple" Foreground="#8DB355" Width="28" Height="28"/>
                                <TextBlock Text="Total Amount Received" Foreground="#8DB355" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding BmlTotalAmount, StringFormat='₱{0:N2}'}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- PWD Count -->
                        <Border Background="#000000" CornerRadius="12" Margin="4,0,4,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Wheelchair" Foreground="White" Width="28" Height="28"/>
                                <TextBlock Text="PWD Beneficiaries" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding BmlPwdCount}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <!-- Senior Count -->
                        <Border Background="#D90000" CornerRadius="12" Margin="4,0,0,0" Padding="20,16">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="HumanCane" Foreground="White" Width="28" Height="28"/>
                                <TextBlock Text="Senior Citizens" Foreground="White" FontSize="13" Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding BmlSeniorCount}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Chart row 1: Gender Pie | Classification Pie -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Gender Pie -->
                        <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="12" Padding="20">
                            <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="260"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <materialDesign:PackIcon Kind="GenderMaleFemale" Foreground="#D90000" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Gender Distribution" FontSize="16" FontWeight="SemiBold" Foreground="#000000" VerticalAlignment="Center"/>
                                </StackPanel>
                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding BmlGenderSeries}"
                                              LegendLocation="Right"
                                              DataTooltip="{x:Null}"/>
                            </Grid>
                        </Border>

                        <!-- Classification Pie -->
                        <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="12" Padding="20">
                            <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="260"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <materialDesign:PackIcon Kind="TagMultipleOutline" Foreground="#8DB355" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Classification Breakdown" FontSize="16" FontWeight="SemiBold" Foreground="#000000" VerticalAlignment="Center"/>
                                </StackPanel>
                                <lvc:PieChart Grid.Row="1"
                                              Series="{Binding BmlClassificationSeries}"
                                              LegendLocation="Right"
                                              DataTooltip="{x:Null}"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Chart row 2: Top 10 Bar | Monthly Trend -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Top 10 Beneficiaries by Amount -->
                        <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="12" Padding="20">
                            <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="260"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <materialDesign:PackIcon Kind="TrophyOutline" Foreground="#8DB355" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Top 10 Beneficiaries by Amount Received" FontSize="16" FontWeight="SemiBold" Foreground="#000000" VerticalAlignment="Center"/>
                                </StackPanel>
                                <lvc:CartesianChart Grid.Row="1" Series="{Binding BmlTopBeneficiarySeries}">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding BmlTopBeneficiaryLabels}" Title="Beneficiary">
                                            <lvc:Axis.Separator><lvc:Separator StrokeThickness="0"/></lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Total Amount (₱)" LabelFormatter="{Binding CurrencyFormatter}"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>

                        <!-- Monthly Trend -->
                        <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="12" Padding="20">
                            <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="260"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <materialDesign:PackIcon Kind="ChartTimelineVariant" Foreground="#D90000" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Monthly Transaction Trend" FontSize="16" FontWeight="SemiBold" Foreground="#000000" VerticalAlignment="Center"/>
                                </StackPanel>
                                <lvc:CartesianChart Grid.Row="1" Series="{Binding BmlMonthlyTrendSeries}">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Labels="{Binding BmlMonthlyTrendLabels}" Title="Month">
                                            <lvc:Axis.Separator><lvc:Separator StrokeThickness="0"/></lvc:Axis.Separator>
                                        </lvc:Axis>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Transactions"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Master Detail Table -->
                    <Border Background="#FFFFFF" CornerRadius="12" Padding="16">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.1"/></Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <materialDesign:PackIcon Kind="TableLarge" Foreground="#8DB355" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Beneficiary Master List" FontSize="16" FontWeight="SemiBold" Foreground="#000000" VerticalAlignment="Center"/>
                                <TextBlock Text=" — enriched with CRS personal data" FontSize="12" Foreground="#8DB355" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding BeneficiaryMasterList}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal" RowHeight="38" HeadersVisibility="Column"
                                      MaxHeight="500">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Beneficiary ID"    Binding="{Binding BeneficiaryId}"                                    Width="130"/>
                                    <DataGridTextColumn Header="Full Name"         Binding="{Binding FullName}"                                         Width="180"/>
                                    <DataGridTextColumn Header="Sex"               Binding="{Binding Sex}"                                              Width="60"/>
                                    <DataGridTextColumn Header="Age"               Binding="{Binding Age}"                                              Width="50"/>
                                    <DataGridTextColumn Header="Marital Status"    Binding="{Binding MaritalStatus}"                                    Width="110"/>
                                    <DataGridTextColumn Header="Barangay"          Binding="{Binding Barangay}"                                         Width="110"/>
                                    <DataGridTextColumn Header="Address"           Binding="{Binding Address}"                                          Width="*"/>
                                    <DataGridTextColumn Header="PWD"               Binding="{Binding IsPwd}"                                            Width="55"/>
                                    <DataGridTextColumn Header="Senior"            Binding="{Binding IsSenior}"                                         Width="60"/>
                                    <DataGridTextColumn Header="Services"          Binding="{Binding ServicesReceived}"                                 Width="70"/>
                                    <DataGridTextColumn Header="Transactions"      Binding="{Binding TotalTransactions}"                                Width="95"/>
                                    <DataGridTextColumn Header="Total Amount"      Binding="{Binding TotalAmount, StringFormat={}{0:C}}"                Width="120"/>
                                    <DataGridTextColumn Header="Last Service"      Binding="{Binding LastServiceDate}"                                  Width="110"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>

