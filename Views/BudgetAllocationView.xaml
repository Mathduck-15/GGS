<UserControl x:Class="GoodGovernanceApp.Views.BudgetAllocationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             xmlns:converters="clr-namespace:GoodGovernanceApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <converters:AllocationColorConverter x:Key="AllocationColorConverter" />
        <converters:ProgressColorConverter x:Key="ProgressColorConverter" />
        <converters:RemainingFundColorConverter x:Key="RemainingFundColorConverter" />
    </UserControl.Resources>

    <UserControl.DataContext>
        <viewmodels:BudgetAllocationViewModel />
    </UserControl.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0 0 0 24" LastChildFill="False">
            <TextBlock Text="Annual Budget Allocation" FontSize="28" FontWeight="Light" Foreground="#000000" VerticalAlignment="Center"/>
            <ComboBox DockPanel.Dock="Right" 
                      ItemsSource="{Binding MasterBudgets}"
                      SelectedItem="{Binding SelectedMasterBudget}"
                      DisplayMemberPath="FiscalYear"
                      materialDesign:HintAssist.Hint="Select Year"
                      Width="150" VerticalAlignment="Center" FontSize="16"/>
        </DockPanel>

        <!-- Allocations Card (Full Width) -->
        <materialDesign:Card Grid.Row="1" Margin="0 0 0 12">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Budget Distribution" FontSize="20" FontWeight="Bold" Margin="0 0 0 16" Foreground="#000000"/>

                <!-- Summary Stats -->
                <Grid Grid.Row="1" Margin="0 0 0 16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Total Budget" Foreground="#000000" FontSize="12"/>
                        <TextBlock Text="{Binding SelectedMasterBudget.TotalAmount, StringFormat=₱{0:N2}}"
                                   Foreground="#000000"
                                   FontSize="20" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Unallocated" Foreground="#000000" FontSize="12"/>
                        <TextBlock Text="{Binding UnallocatedAmount, StringFormat=₱{0:N2}}"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{Binding UnallocatedAmount, Converter={StaticResource AllocationColorConverter}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Allocated %" Foreground="#000000" FontSize="12"/>
                        <TextBlock Text="{Binding AllocationPercent, StringFormat={}{0:N1}%}"
                                   Foreground="#000000"
                                   FontSize="20" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>

                <!-- Allocations DataGrid -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding DepartmentAllocations}"
                          SelectedItem="{Binding SelectedOffice}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          IsReadOnly="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Office Code"
                                            Binding="{Binding OfficeCode}"
                                            IsReadOnly="True" Width="150" FontFamily="Consolas"/>
                        <DataGridTextColumn Header="Department"
                                            Binding="{Binding DepartmentName}"
                                            IsReadOnly="True" Width="*"/>
                        <DataGridTemplateColumn Header="Allocated (₱)" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Spent (₱)"
                                            Binding="{Binding SpentDisplay}"
                                            IsReadOnly="True" Width="120"/>
                        <DataGridTextColumn Header="Remaining (₱)"
                                            Binding="{Binding RemainingDisplay}"
                                            IsReadOnly="True" Width="120"/>
                        <DataGridTemplateColumn Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="View Projects" 
                                            Command="{Binding DataContext.ViewProjectsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Height="30" Padding="8 0" FontSize="12"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Footer -->
                <StackPanel Grid.Row="3" Margin="0 12 0 0">
                    <ProgressBar Value="{Binding AllocationPercent}" Height="8" Margin="0 0 0 12"
                                 Foreground="{Binding UnallocatedAmount, Converter={StaticResource ProgressColorConverter}}"/>
                    <Button Content="💾 Save Allocations" Command="{Binding SaveAllocationsCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
