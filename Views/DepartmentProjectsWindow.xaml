<Window x:Class="GoodGovernanceApp.Views.DepartmentProjectsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Department Projects" Height="650" Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0 0 0 16">
            <TextBlock Text="Projects &amp; Spendings" FontSize="20" FontWeight="Bold" Foreground="#000000" VerticalAlignment="Center"/>
            <Button Content="＋ Add Project" Command="{Binding AddProjectCommand}" 
                    HorizontalAlignment="Right" Style="{StaticResource MaterialDesignRaisedButton}" DockPanel.Dock="Right"/>
        </DockPanel>

        <!-- Tier 3 Warning Alert -->
        <materialDesign:Card Grid.Row="1" Background="#FFF4E5" Foreground="#663C00" Margin="0 0 0 16" Padding="12">
            <materialDesign:Card.Style>
                <Style TargetType="materialDesign:Card">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding UnidentifiedCount}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </materialDesign:Card.Style>
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AlertCircleOutline" Width="24" Height="24" VerticalAlignment="Center" Margin="0 0 8 0" Foreground="#FFA000"/>
                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="500">
                    <Run Text="⚠️ Warning: " FontWeight="Bold"/>
                    <Run Text="{Binding UnidentifiedCount, Mode=OneWay}"/>
                    <Run Text=" transaction(s) totaling ₱"/>
                    <Run Text="{Binding UnidentifiedAmount, StringFormat={}{0:N2}, Mode=OneWay}"/>
                    <Run Text=" are missing both Project ID and Name, making them impossible to map."/>
                </TextBlock>
            </StackPanel>
        </materialDesign:Card>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Tier 1: Official Projects -->
                <TextBlock Text="Official Mapped Projects" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 8"/>
                <DataGrid ItemsSource="{Binding OfficeProjects}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          IsReadOnly="True"
                          Margin="0 0 0 24" MaxHeight="250">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Project Details ID" Binding="{Binding ProjectDetailsID}" Width="150" FontFamily="Consolas"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Budget (₱)" Binding="{Binding Budget, StringFormat=₱{0:N2}}" Width="120"/>
                        <DataGridTextColumn Header="Spent (₱)" Binding="{Binding Spent, StringFormat=₱{0:N2}}" Width="120"/>
                        <DataGridTextColumn Header="Remaining (₱)" Binding="{Binding Remaining, StringFormat=₱{0:N2}}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Tier 2: Unmapped Local Spend -->
                <TextBlock Text="Unmapped Local Transactions" FontWeight="SemiBold" FontSize="14" Margin="0 0 0 8"/>
                <TextBlock Text="These transactions have a local project code but no matching GGMS project ID or Name." 
                           FontStyle="Italic" Foreground="#666666" Margin="0 0 0 8" FontSize="11"/>
                <DataGrid ItemsSource="{Binding UnmappedIdentifiedProjects}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          IsReadOnly="True"
                          MaxHeight="250">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Local Code" Binding="{Binding ProjectCode}" Width="150" FontFamily="Consolas"/>
                        <DataGridTextColumn Header="Local Name" Binding="{Binding ProjectName}" Width="*"/>
                        <DataGridTextColumn Header="Spent (₱)" Binding="{Binding SpentDisplay}" Width="120"/>
                    </DataGrid.Columns>
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UnmappedIdentifiedProjects.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                </DataGrid>
                
                <!-- Helper text when no unmapped transactions -->
                <TextBlock Text="No unmapped transactions. Great job!" FontStyle="Italic" Foreground="#4CAF50" Margin="0 8 0 0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UnmappedIdentifiedProjects.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="3" Content="Close" Click="CloseButton_Click" 
                HorizontalAlignment="Right" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0 16 0 0"/>
    </Grid>
</Window>
