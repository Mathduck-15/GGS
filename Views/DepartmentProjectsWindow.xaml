<Window x:Class="GoodGovernanceApp.Views.DepartmentProjectsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Department Projects" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0 0 0 16">
            <TextBlock Text="Projects &amp; Spendings" FontSize="20" FontWeight="Bold" Foreground="#000000" VerticalAlignment="Center"/>
            <Button Content="＋ Add Project" Command="{Binding AddProjectCommand}" 
                    HorizontalAlignment="Right" Style="{StaticResource MaterialDesignRaisedButton}" DockPanel.Dock="Right"/>
        </DockPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding OfficeProjects}" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  IsReadOnly="True"
                  Margin="0 0 0 16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Project Code" Binding="{Binding ProjectDetailsID}" Width="120" FontFamily="Consolas"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Spent (₱)" Binding="{Binding Spent, StringFormat=₱{0:N2}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="Close" Click="CloseButton_Click" 
                HorizontalAlignment="Right" Style="{StaticResource MaterialDesignOutlinedButton}"/>
    </Grid>
</Window>
