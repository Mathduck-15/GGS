<Window x:Class="GoodGovernanceApp.Views.VoucherPrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GoodGovernanceApp.Views"
        mc:Ignorable="d"
        Title="VoucherPrintWindow" Height="450" Width="800">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Margin="40" Padding="40" BorderBrush="#CCCCCC" BorderThickness="1"
            Background="White">
                <StackPanel>

                    <!-- Header -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                        <TextBlock Text="REPUBLIC OF THE PHILIPPINES"
                           FontSize="11" HorizontalAlignment="Center"
                           Foreground="#555555"/>
                        <TextBlock Text="GOOD GOVERNANCE APP"
                           FontSize="13" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Foreground="#555555"/>
                        <Separator Margin="0,10,0,10" Background="#CCCCCC"/>
                        <TextBlock Text="DISBURSEMENT VOUCHER"
                           FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Voucher Info Grid -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 1 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Voucher No.:"
                           FontWeight="SemiBold" Foreground="#555"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding Row.VoucherCode}"
                           Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Date:"
                           FontWeight="SemiBold" Foreground="#555"/>
                        <TextBlock Grid.Row="0" Grid.Column="3"
                           Text="{Binding Row.Date, StringFormat='{}{0:MMMM dd, yyyy}'}"
                           Margin="0,0,0,8"/>

                        <!-- Row 2 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Project Code:"
                           FontWeight="SemiBold" Foreground="#555"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding Row.ProjectCode}"
                           Margin="0,0,0,8"/>

                        <!-- Row 3 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Project Name:"
                           FontWeight="SemiBold" Foreground="#555"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                           Text="{Binding Row.ProjectName}"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </Grid>

                    <Separator Background="#CCCCCC" Margin="0,0,0,20"/>

                    <!-- Amount Box -->
                    <Border Background="#F5F5F5" BorderBrush="#CCCCCC"
                    BorderThickness="1" Padding="20" Margin="0,0,0,30">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TOTAL AMOUNT"
                               FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                               Text="{Binding Row.Amount, StringFormat='{}{0:PHP #,##0.00}'}"
                               FontSize="20" FontWeight="Bold" Foreground="#1a6b3c"/>
                        </Grid>
                    </Border>

                    <!-- Signature Section -->
                    <Grid Margin="0,10,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Prepared By -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                            Width="180" Margin="0,40,0,4"/>
                            <TextBlock Text="Prepared By" HorizontalAlignment="Center"
                               FontWeight="SemiBold" FontSize="11"/>
                            <TextBlock Text="Signature over Printed Name"
                               HorizontalAlignment="Center"
                               Foreground="#888" FontSize="10"/>
                        </StackPanel>

                        <!-- Approved By -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"
                            Width="180" Margin="0,40,0,4"/>
                            <TextBlock Text="Approved By" HorizontalAlignment="Center"
                               FontWeight="SemiBold" FontSize="11"/>
                            <TextBlock Text="Signature over Printed Name"
                               HorizontalAlignment="Center"
                               Foreground="#888" FontSize="10"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#CCCCCC" Margin="0,0,0,10"/>

                    <!-- Footer -->
                    <TextBlock Text="This voucher is system-generated and valid without signature when printed."
                       FontSize="9" Foreground="#AAAAAA"
                       HorizontalAlignment="Center" TextWrapping="Wrap"/>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
