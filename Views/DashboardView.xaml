<UserControl x:Class="GoodGovernanceApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">
             
    <UserControl.DataContext>
        <viewmodels:DashboardViewModel/>
    </UserControl.DataContext>

    <ScrollViewer>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Dashboard Overview" FontSize="28" FontWeight="Light" Margin="0 0 0 24"   Foreground="#000000"/>


            <!-- Summary Cards -->
            <UniformGrid Grid.Row="1" Columns="4" Rows="1">
                <!-- Total Budget Card -->
                <materialDesign:Card Margin="8" Padding="16" UniformCornerRadius="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                            <materialDesign:PackIcon Kind="BankOutline" Width="32" Height="32"  Foreground="#000000"/>
                            <TextBlock Text="Total Budget this year" FontSize="16" Foreground="#000000" VerticalAlignment="Center" Margin="8 0 0 0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalBudget, StringFormat=PHP {0:N2}}" FontSize="28" FontWeight="SemiBold"  Foreground="#000000"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Total Income Card -->
           

                <!-- Total Expense Card -->
                <materialDesign:Card Margin="8" Padding="16" UniformCornerRadius="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                            <materialDesign:PackIcon Kind="TrendingDown" Width="32" Height="32" Foreground="Red"/>
                            <TextBlock Text="Total Expense" FontSize="16" Foreground="#000000" VerticalAlignment="Center" Margin="8 0 0 0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalExpense, StringFormat={}{0:C}}" FontSize="28" FontWeight="SemiBold" Foreground="Red"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Active Users Card -->
                <materialDesign:Card Margin="8" Padding="16" UniformCornerRadius="8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                            <materialDesign:PackIcon Kind="AccountGroupOutline" Width="32" Height="32"  Foreground="#000000"/>
                            <TextBlock Text="Active Users" FontSize="16" Foreground="#000000" VerticalAlignment="Center" Margin="8 0 0 0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveUsersCount}" FontSize="28" FontWeight="SemiBold"  Foreground="#000000"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Chart Area -->
            <Grid Grid.Row="2" Margin="0 8 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Custom Bar Chart (Vanilla XAML) -->
                <materialDesign:Card Grid.Column="0" Margin="8" Padding="16" UniformCornerRadius="8" MinHeight="400">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Financial Performance (Income vs Expense)" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 16"  Foreground="#000000"/>
                        
                        <!-- Chart Area -->
                        <Grid Grid.Row="1" VerticalAlignment="Bottom" Height="300" Margin="20 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            
                           

                            <!-- Expense Bar -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding TotalExpense, StringFormat={}{0:C0}}" HorizontalAlignment="Center" Margin="0 0 0 4" FontSize="12" FontWeight="Bold" Foreground="Red"/>
                                <Border Height="{Binding ExpenseHeight}" Width="60" CornerRadius="4 4 0 0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <GradientStop Color="#FFF44336" Offset="0"/>
                                            <GradientStop Color="#88F44336" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="Expense" HorizontalAlignment="Center" Margin="0 8 0 0" FontWeight="SemiBold"  Foreground="#000000"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </materialDesign:Card>

                <!-- Dept Summary (Custom XAML) -->
                <materialDesign:Card Grid.Column="1" Margin="8" Padding="16" UniformCornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Budget Distribution" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 16"  Foreground="#000000"/>

                        <lvc:PieChart Grid.Row="1" 
                        Series="{Binding DeptPieSeries}" 
                        Height="250"/>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="2" Margin="8" Padding="16" UniformCornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Budget project" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 16"  Foreground="#000000"/>

                        <lvc:PieChart Grid.Row="1" 
                        Series="{Binding DeptProjectPieSeries}" 
                         Height="250"/>
                    </Grid>
                </materialDesign:Card>
            </Grid>

        </Grid>
    </ScrollViewer>
</UserControl>
