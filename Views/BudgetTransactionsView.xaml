<UserControl x:Class="GoodGovernanceApp.Views.BudgetTransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.DataContext>
        <viewmodels:BudgetTransactionsViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title + Refresh -->
            <RowDefinition Height="Auto"/>  <!-- Filter bar -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Loading indicator -->
        </Grid.RowDefinitions>

        <!-- ── Title & Refresh ──────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0 0 0 12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Transactions" FontSize="24" FontWeight="Light" VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="↻  Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
        </Grid>

        <!-- ── Filter Bar ────────────────────────────────────────────────── -->
        <materialDesign:Card Grid.Row="1" Padding="12 8" Margin="0 0 0 12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>   <!-- Free-text search -->
                    <ColumnDefinition Width="*"/>    <!-- Office Code -->
                    <ColumnDefinition Width="2*"/>   <!-- Project Code / Name -->
                    <ColumnDefinition Width="*"/>    <!-- Status dropdown -->
                    <ColumnDefinition Width="Auto"/> <!-- Clear button -->
                </Grid.ColumnDefinitions>

                <!-- Free-text search -->
                <TextBox Grid.Column="0"
                         materialDesign:HintAssist.Hint="Search all columns…"
                         Text="{Binding FilterFreeText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0 0 8 0"/>

                <!-- Office Code filter -->
                <TextBox Grid.Column="1"
                         materialDesign:HintAssist.Hint="Office Code"
                         Text="{Binding FilterOfficeCode, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0 0 8 0"/>

                <!-- Project Code / Name filter -->
                <TextBox Grid.Column="2"
                         materialDesign:HintAssist.Hint="Project Code or Name"
                         Text="{Binding FilterProjectCode, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0 0 8 0"/>

                <!-- Status dropdown -->
                <ComboBox Grid.Column="3"
                          materialDesign:HintAssist.Hint="Status"
                          ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding FilterStatus}"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                          Margin="0 0 8 0"/>

                <!-- Clear filters -->
                <Button Grid.Column="4"
                        Content="Clear"
                        Command="{Binding ClearFilterCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </materialDesign:Card>

        <!-- ── Transactions DataGrid ─────────────────────────────────────── -->
        <materialDesign:Card Grid.Row="2" Padding="0">
            <DataGrid AutoGenerateColumns="False"
            IsReadOnly="True"
            ItemsSource="{Binding TransactionsView}"
            RowHeight="40"
            HeadersVisibility="Column"
            GridLinesVisibility="None"
            Background="White"
            BorderThickness="0">

                <!-- 🔷 Header Style -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="8"/>
                        <Setter Property="Background" Value="#F5F5F5"/>
                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- 🔷 Row Style -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9FBFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DCEEFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <!-- 🔹 Project Code -->
                    <DataGridTextColumn Header="Project Code"
                            Binding="{Binding ProjectCode}"
                            Width="170">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 🔹 Project Name -->
                    <DataGridTextColumn Header="Project Name"
                            Binding="{Binding ProjectName}"
                            Width="230">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 🔹 Voucher Code -->
                    <DataGridTextColumn Header="Voucher Code"
                            Binding="{Binding VoucherCode}"
                            Width="210">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 💰 Amount -->
                    <DataGridTextColumn Header="Amount"
                            Binding="{Binding Amount, StringFormat='{}{0:C}'}"
                            Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="5,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 📅 Date -->
                    <DataGridTextColumn Header="Date"
                            Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}"
                            Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 🎯 Actions -->
                    <DataGridTemplateColumn Header="Actions" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Center">
                                    <Button Content="Voucher"
                                Padding="10,4"
                                Cursor="Hand"
                                Background="Purple"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="12"
                                HorizontalAlignment="Center"
                                Command="{Binding DataContext.PrintVoucherCommand, 
                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                CommandParameter="{Binding}">

                                        <!-- Rounded Button -->
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>

                                                <!-- Hover effect -->
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#45A049"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>

                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!-- ── Loading Indicator ─────────────────────────────────────────── -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 8 0 0"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True"
                         Width="20" Height="20"
                         Margin="0 0 8 0"/>
            <TextBlock Text="Loading transactions…"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"/>
        </StackPanel>
    </Grid>
</UserControl>
