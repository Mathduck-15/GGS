<UserControl x:Class="GoodGovernanceApp.Views.CrsBeneficiaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.DataContext>
        <viewmodels:CrsBeneficiaryViewModel />
    </UserControl.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0 0 0 20">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AccountGroup" Width="28" Height="28"
                                         VerticalAlignment="Center" Margin="0 0 10 0"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="CRS Beneficiary Records" FontSize="28" FontWeight="Light" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Civil Registry System — READ ONLY reference data" FontSize="13"
                       Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="38 4 0 0"/>
        </StackPanel>

        <!-- Status Bar -->
        <materialDesign:Card Grid.Row="1" Padding="16" Margin="0 0 0 16">
            <StackPanel Orientation="Horizontal">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0 0 16 0">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesignBody}"/>
                </StackPanel>
                <ProgressBar IsIndeterminate="True" Width="24" Height="24" VerticalAlignment="Center"
                             Style="{StaticResource MaterialDesignCircularProgressBar}" Margin="0 0 16 0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <Button Content="🔄 Load from CRS" Command="{Binding LoadCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBooleanConverter}}"
                        HorizontalAlignment="Right"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Data Grid -->
        <materialDesign:Card Grid.Row="2" Padding="8">
            <Grid>
                <DataGrid ItemsSource="{Binding Beneficiaries}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              IsReadOnly="True"
              SelectionMode="Single"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Auto"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Beneficiary ID"
                Binding="{Binding BeneficiaryId}" Width="170"/>

                        <DataGridTextColumn Header="Last Name"
                Binding="{Binding LastName}" Width="1.5*"/>

                        <DataGridTextColumn Header="First Name"
                Binding="{Binding FirstName}" Width="1.5*"/>

                        <DataGridTextColumn Header="Middle Name"
                Binding="{Binding MiddleName}" Width="1*"/>

                        <DataGridTextColumn Header="Sex"
                Binding="{Binding Sex}" Width="80"/>

                        <DataGridTextColumn Header="Date of Birth"
                Binding="{Binding DisplayDateOfBirth}" Width="130"/>

                        <DataGridTextColumn Header="Age"
                Binding="{Binding DisplayAge}" Width="100"/>

                        <DataGridTextColumn Header="Marital Status"
                Binding="{Binding MaritalStatus}" Width="120"/>

                        <DataGridTextColumn Header="Classifications"
                Binding="{Binding Classifications}" Width="160"/>

                        <DataGridCheckBoxColumn Header="PWD"
                Binding="{Binding IsPwd}" Width="60"/>

                        <DataGridTextColumn Header="PWD ID"
                Binding="{Binding PwdIdNo}" Width="120"/>

                        <DataGridCheckBoxColumn Header="Senior"
                Binding="{Binding IsSenior}" Width="70"/>

                        <DataGridTextColumn Header="Senior ID"
                Binding="{Binding SeniorIdNo}" Width="120"/>

                        <DataGridTextColumn Header="Address"
                Binding="{Binding Address}" Width="2*"/>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
