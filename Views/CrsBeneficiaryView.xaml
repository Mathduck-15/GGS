<UserControl x:Class="GoodGovernanceApp.Views.CrsBeneficiaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.DataContext>
        <viewmodels:CrsBeneficiaryViewModel />
    </UserControl.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0 0 0 20">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AccountGroup" Width="28" Height="28"
                                         VerticalAlignment="Center" Margin="0 0 10 0"
                                         
                                           Foreground="#000000"/>
                <TextBlock Text="CRS Beneficiary Records" FontSize="28" FontWeight="Light" VerticalAlignment="Center"   Foreground="#000000"/>
            </StackPanel>
            <TextBlock Text="Civil Registry System — READ ONLY reference data" FontSize="13"
                       Foreground="#000000" Margin="38 4 0 0"/>
        </StackPanel>

        <!-- Toolbar: Search + Load -->
        <materialDesign:Card Grid.Row="1" Padding="16" Margin="0 0 0 16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Beneficiary ID Label + Box -->
                <TextBlock Grid.Column="0" Text="Beneficiary ID:" VerticalAlignment="Center"
                           FontWeight="Medium" Foreground="#000000" Margin="0 0 8 0"/>
                <TextBox Grid.Column="1"
                         materialDesign:HintAssist.Hint="e.g. BEN-00123"
                         Text="{Binding BeneficiaryIdFilter, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="#000000"
                         VerticalAlignment="Center"
                         x:Name="BeneficiaryIdBox"/>
                <Button Grid.Column="2"
                        Content="Search"
                        Command="{Binding SearchByIdCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        VerticalAlignment="Center"
                        Margin="8 0 0 0"/>

                <!-- Divider -->
                <Separator Grid.Column="3" Style="{StaticResource MaterialDesignDarkSeparator}"
                           Margin="0" VerticalAlignment="Stretch"/>

                <!-- Free-text search -->
                <TextBox Grid.Column="4"
                         materialDesign:HintAssist.Hint="Filter by name, address…"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="#000000"
                         VerticalAlignment="Center"/>

                <!-- Status + spinner -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="8 0">
                    <ProgressBar IsIndeterminate="True" Width="20" Height="20"
                                 Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Margin="0 0 8 0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{DynamicResource MaterialDesignBody}"
                               VerticalAlignment="Center" MaxWidth="260" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Clear -->
                <Button Grid.Column="7"
                        Content="Clear"
                        Command="{Binding ClearCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        VerticalAlignment="Center"/>

                <!-- Load -->
                <Button Grid.Column="9"
                        Content="🔄 Load First 50"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBooleanConverter}}"
                        VerticalAlignment="Center"/>
            </Grid>
        </materialDesign:Card>


        <!-- Data Grid -->
        <materialDesign:Card Grid.Row="2" Padding="8">
            <Grid>
                <DataGrid ItemsSource="{Binding Beneficiaries}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              IsReadOnly="True"
              SelectionMode="Single"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Auto"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">

                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Beneficiary ID" Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                                            Content="{Binding BeneficiaryId}"
                                            Command="{Binding DataContext.OpenAnalyticsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                            Padding="0" Height="Auto"
                                            HorizontalAlignment="Left"
                                            ToolTip="View Comparison Analytics" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Last Name"
                Binding="{Binding LastName}" Width="1.5*"/>

                        <DataGridTextColumn Header="First Name"
                Binding="{Binding FirstName}" Width="1.5*"/>

                        <DataGridTextColumn Header="Middle Name"
                Binding="{Binding MiddleName}" Width="1*"/>

                        <DataGridTextColumn Header="Sex"
                Binding="{Binding Sex}" Width="80"/>

                        <DataGridTextColumn Header="Date of Birth"
                Binding="{Binding DisplayDateOfBirth}" Width="130"/>

                        <DataGridTextColumn Header="Age"
                Binding="{Binding DisplayAge}" Width="100"/>

                        <DataGridTextColumn Header="Marital Status"
                Binding="{Binding MaritalStatus}" Width="120"/>

                        <DataGridTextColumn Header="Classifications"
                Binding="{Binding Classifications}" Width="160"/>

                        <DataGridCheckBoxColumn Header="PWD"
                Binding="{Binding IsPwd}" Width="60"/>

                        <DataGridTextColumn Header="PWD ID"
                Binding="{Binding PwdIdNo}" Width="120"/>

                        <DataGridCheckBoxColumn Header="Senior"
                Binding="{Binding IsSenior}" Width="70"/>

                        <DataGridTextColumn Header="Senior ID"
                Binding="{Binding SeniorIdNo}" Width="120"/>

                        <DataGridTextColumn Header="Address"
                Binding="{Binding Address}" Width="2*"/>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
