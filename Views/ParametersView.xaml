<UserControl x:Class="GoodGovernanceApp.Views.ParametersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:GoodGovernanceApp.Views"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
             
    <UserControl.DataContext>
        <viewmodels:ParametersViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side: Categories -->
        <materialDesign:Card Grid.Column="0" Margin="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Categories" FontSize="20" FontWeight="Bold" Margin="0 0 0 16"/>

                <StackPanel Grid.Row="1" Margin="0 0 0 16">
                    <TextBox materialDesign:HintAssist.Hint="Category Name" Text="{Binding SelectedCategory.Name}" 
                             IsEnabled="{Binding IsEditingCategory}" Margin="0 0 0 8" />
                    <TextBox materialDesign:HintAssist.Hint="Description" Text="{Binding SelectedCategory.Description}" 
                             IsEnabled="{Binding IsEditingCategory}" Margin="0 0 0 16" />
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="ADD" Command="{Binding AddCategoryCommand}" Margin="0 0 4 0" 
                                Visibility="{Binding IsNotEditingCategory, Converter={StaticResource BoolToVis}}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        <Button Content="EDIT" Command="{Binding AddCategoryCommand}" Margin="0 0 4 0" 
                                Visibility="{Binding IsNotEditingCategory, Converter={StaticResource BoolToVis}}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        <Button Content="DELETE" Command="{Binding DeleteCategoryCommand}" Margin="0 0 4 0" Foreground="Red"
                                Visibility="{Binding IsNotEditingCategory, Converter={StaticResource BoolToVis}}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        <Button Content="SAVE" Command="{Binding SaveCategoryCommand}" Margin="0 0 4 0" 
                                Visibility="{Binding IsEditingCategory, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="CANCEL" Command="{Binding CancelCategoryCommand}" Style="{StaticResource MaterialDesignFlatButton}" 
                                Visibility="{Binding IsEditingCategory, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </StackPanel>

                <DataGrid Grid.Row="2" ItemsSource="{Binding Categories}" AutoGenerateColumns="False" 
                          SelectedItem="{Binding SelectedCategory}" IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- Right Side: Parameters -->
        <materialDesign:Card Grid.Column="1" Margin="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="System Parameters" FontSize="20" FontWeight="Bold" Margin="0 0 0 16"/>

                <StackPanel Grid.Row="1" Margin="0 0 0 16">
                    <TextBox materialDesign:HintAssist.Hint="Parameter Name" Text="{Binding SelectedParameter.Name}" 
                             IsEnabled="{Binding IsEditingParameter}" Margin="0 0 0 8" />
                    <TextBox materialDesign:HintAssist.Hint="Value" Text="{Binding SelectedParameter.Value}" 
                             IsEnabled="{Binding IsEditingParameter}" Margin="0 0 0 8" />
                    <TextBox materialDesign:HintAssist.Hint="Description" Text="{Binding SelectedParameter.Description}" 
                             IsEnabled="{Binding IsEditingParameter}" Margin="0 0 0 16" />
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="ADD" Command="{Binding AddParameterCommand}" Margin="0 0 4 0" 
                                Visibility="{Binding IsNotEditingParameter, Converter={StaticResource BoolToVis}}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        <Button Content="EDIT" Command="{Binding AddParameterCommand}" Margin="0 0 4 0" 
                                Visibility="{Binding IsNotEditingParameter, Converter={StaticResource BoolToVis}}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        <Button Content="DELETE" Command="{Binding DeleteParameterCommand}" Margin="0 0 4 0" Foreground="Red"
                                Visibility="{Binding IsNotEditingParameter, Converter={StaticResource BoolToVis}}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        <Button Content="SAVE" Command="{Binding SaveParameterCommand}" Margin="0 0 4 0" 
                                Visibility="{Binding IsEditingParameter, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="CANCEL" Command="{Binding CancelParameterCommand}" Style="{StaticResource MaterialDesignFlatButton}" 
                                Visibility="{Binding IsEditingParameter, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </StackPanel>

                <DataGrid Grid.Row="2" ItemsSource="{Binding Parameters}" AutoGenerateColumns="False" 
                          SelectedItem="{Binding SelectedParameter}" IsReadOnly="True" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
