<UserControl x:Class="GoodGovernanceApp.Views.DepartmentManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    
    <UserControl.DataContext>
        <viewmodels:DepartmentManagementViewModel />
    </UserControl.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Department &amp; Project Management" FontSize="28" FontWeight="Light" Margin="0 0 0 24"   Foreground="#000000"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="300"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Departments List -->
            <materialDesign:Card Grid.Column="0" Margin="0 0 12 0" VerticalAlignment="Stretch">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Departments" FontSize="18" FontWeight="Bold" Margin="0 0 0 12"  Foreground="#000000"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" Margin="0 0 0 12">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4 2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding OfficeCode}" FontFamily="Consolas" FontSize="11"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2">
                        <!-- Auto-generated Office Code -->
                        <TextBlock Text="Office ID" FontSize="11" Foreground="#000000" Margin="0 0 0 2"/>
                        <Grid Margin="0 0 0 8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewOfficeCode, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Office Code (auto-generated)"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     Foreground="#000000"
                                     FontWeight="Bold"/>
                            <Button Grid.Column="1" Content="↻" ToolTip="Generate new code"
                                    Command="{Binding RegenerateCodeCommand}"
                                    Style="{StaticResource MaterialDesignToolButton}"
                                    Margin="4 0 0 0"/>
                        </Grid>

                        <TextBox materialDesign:HintAssist.Hint="New Department Name" Text="{Binding NewDepartmentName, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 0 8"  Foreground="#000000"/>
                        <TextBox materialDesign:HintAssist.Hint="Description" Text="{Binding NewDepartmentDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 0 12"  Foreground="#000000"/>
                        <Button Content="Add Department" Command="{Binding AddDepartmentCommand}" Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- Projects Detail Area (visible when a department is selected) -->
            <Grid Grid.Column="1" Margin="12 0 0 0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedDepartment}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Department header card -->
                <materialDesign:Card Padding="16" Margin="0 0 0 16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedDepartment.Name}" FontSize="24" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedDepartment.Description}" FontSize="14" Foreground="#000000" Margin="0 4 0 0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Delete Department" Command="{Binding DeleteDepartmentCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="Red" BorderBrush="Red" VerticalAlignment="Bottom"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Projects table card -->
                <materialDesign:Card Grid.Row="1" VerticalAlignment="Stretch">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with Add Project button -->
                        <Grid Margin="0 0 0 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Department Projects" FontSize="18" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Allocate Budget"
                                        Command="{Binding AllocateBudgetCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Margin="0 0 8 0"
                                        Padding="12 6"/>
                                <Button Content="＋ Add Project"
                                        Command="{Binding AddProjectCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Padding="12 6"/>
                            </StackPanel>
                        </Grid>

                        <!-- Projects DataGrid -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ProjectDetails}"
                                  SelectedItem="{Binding SelectedRole}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Project ID"     Binding="{Binding ProjectDetailsID}" Width="130"/>
                                <DataGridTextColumn Header="Voucher Code"   Binding="{Binding VoucherCode}"      Width="110"/>
                                <DataGridTextColumn Header="Project"        Binding="{Binding Name}"             Width="200"/>
                                <DataGridTextColumn Header="Description"    Binding="{Binding Description}"      Width="200"/>
                                <DataGridTextColumn Header="Office Code"    Binding="{Binding OfficeCode}"       Width="130"/>
                                <DataGridTextColumn Header="Total Budget"   Binding="{Binding Budget, StringFormat='{}{0:C}'}" Width="140"/>
                                <DataGridTextColumn Header="Spent"          Binding="{Binding Spent, StringFormat='{}{0:C}'}"  Width="140"/>
                                <DataGridTextColumn Header="Remaining"      Binding="{Binding Remaining, StringFormat='{}{0:C}'}" Width="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Contact Person" Binding="{Binding ContactPerson}"   Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- Empty State (visible when no department selected) -->
            <materialDesign:Card Grid.Column="1" Margin="12 0 0 0" Padding="32">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedDepartment}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="OfficeBuilding" Width="64" Height="64" HorizontalAlignment="Center" Foreground="#000000"/>
                    <TextBlock Text="Select a department to view or manage its projects." FontSize="18" Margin="0 16 0 0" Foreground="#000000" TextAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
