<Window x:Class="GoodGovernanceApp.Views.AddProjectWindow"
        xmlns:converters="clr-namespace:GoodGovernanceApp.Converters"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodels="clr-namespace:GoodGovernanceApp.ViewModels"
        Title="Add New Project"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.DataContext>
        <viewmodels:AddProjectViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0 0 0 20">
            <TextBlock Text="Add New Project" FontSize="22" FontWeight="Light"/>
            <TextBlock Text="Fill in the details below. Fields marked * are required."
                       FontSize="12" Foreground="#000000"
                       Margin="0 4 0 0"/>
        </StackPanel>

        <!-- Form -->
        <materialDesign:Card Grid.Row="1" Padding="20" Margin="0 0 0 16">
            <StackPanel>

                <!-- Project ID (read-only) -->
                <TextBlock Text="Project ID" FontSize="11"
                           
                           Margin="0 0 0 2"/>
                <TextBox Text="{Binding ProjectId, Mode=OneWay}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontWeight="Bold"
                         Foreground="#000000"
                         materialDesign:HintAssist.Hint="Auto-generated"
                         Margin="0 0 0 16"/>

                <!-- Voucher Code (read-only) -->
                <TextBlock Text="Voucher Code" FontSize="11"
                           
                           Margin="0 0 0 2"/>
                <TextBox Text="{Binding VoucherCode, Mode=OneWay}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontWeight="Bold"
                         
                         materialDesign:HintAssist.Hint="Auto-generated"
                         Foreground="#000000"
                         Margin="0 0 0 16"/>

                <!-- Project Name * -->
                <TextBox materialDesign:HintAssist.Hint="Project Name *"
                         Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 0 0 16"/>

                <!-- Description -->
                <TextBox materialDesign:HintAssist.Hint="Description"
                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinLines="2" MaxLines="4"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0 0 0 16"/>

                <!-- Year Filter -->
                <Grid Margin="0 0 0 16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Filter Year (required)" FontSize="11"
                                   Foreground="#000000"
                                   Margin="0 0 0 2"/>
                        <TextBlock Text="{Binding SelectedYear, StringFormat='Selected year: {0}', FallbackValue='No year selected'}"
                                   FontSize="12"   Foreground="#000000"/>
                    </StackPanel>

                    <!-- Year picker popup button -->
                    <Grid Grid.Column="1" VerticalAlignment="Bottom">
                        <Grid.Resources>
                            <Popup x:Key="YearPopup"/>
                        </Grid.Resources>
                        <Button x:Name="YearButton"
                                Content="Select Year  ▾"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Click="YearButton_Click"/>
                        <Popup x:Name="YearPopup"
                               PlacementTarget="{Binding ElementName=YearButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <materialDesign:Card Padding="4" MinWidth="140">
                                <StackPanel>
                                    <TextBlock Text="Select Year" FontSize="11" FontWeight="Bold"
                                               Margin="8 6 8 2"
                                               Foreground="#000000"/>
                                    <ListBox x:Name="YearListBox"
                                             ItemsSource="{Binding AvailableYears}"
                                             SelectedItem="{Binding SelectedYear}"
                                             SelectionChanged="YearListBox_SelectionChanged"
                                             MaxHeight="180"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                    <Separator/>
                                    <Button Content="Clear"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            HorizontalAlignment="Stretch"
                                            Click="ClearYear_Click"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </Popup>
                    </Grid>
                </Grid>

                <!-- Office Code * -->
                <TextBlock Text="Office Code *" FontSize="11"
                          
                           Margin="0 0 0 2"/>
                <ComboBox ItemsSource="{Binding FilteredOfficeCodes}"
                          SelectedItem="{Binding SelectedOfficeCode}"
                          materialDesign:HintAssist.Hint="Select Office Code"
                          IsEditable="False"
                          Margin="0 0 0 16"/>

                <!-- Total Budget -->
                <TextBox materialDesign:HintAssist.Hint="Total Budget (numeric)"
                         Text="{Binding TotalBudget, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 0 0 16"/>

                <!-- Beneficiary ID Lookup -->
                <TextBlock Text="Beneficiary" FontSize="11" Foreground="#000000" Margin="0 0 0 4"/>
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             materialDesign:HintAssist.Hint="Enter Beneficiary ID"
                             Text="{Binding BeneficiaryId, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="#000000"
                             Margin="0 0 8 0"
                             KeyDown="BeneficiaryIdBox_KeyDown"
                             x:Name="BeneficiaryIdBox"/>
                    <Button Grid.Column="1"
                            Content="Search"
                            Command="{Binding LookupBeneficiaryCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            VerticalAlignment="Bottom"/>
                </Grid>

                <!-- Resolved Beneficiary Name (read-only) -->
                <Border Background="#F5F5F5" CornerRadius="4" Padding="10 8" Margin="0 0 0 4"
                        Visibility="{Binding HasBeneficiary, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountCheck" Foreground="#388E3C" VerticalAlignment="Center" Margin="0 0 6 0"/>
                        <TextBlock Text="{Binding BeneficiaryName}" Foreground="#388E3C" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="No beneficiary found for that ID."
                           Foreground="#D32F2F" FontSize="11"
                           Visibility="{Binding ShowNotFound, Converter={StaticResource BoolToVis}}"
                           Margin="0 0 0 4"/>

            </StackPanel>
        </materialDesign:Card>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0 0 8 0"
                    Click="Cancel_Click"/>
            <Button Content="Save Project"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>
